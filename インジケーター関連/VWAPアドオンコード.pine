plot(display_npr60m and not hideMSandBBNPR and not hide_npr_bb_on_4hr ? npr60m_lower : na, "60m NPR Lower", color=color.new(npr60m_color, 30), linewidth=3, style=plot.style_line, linestyle=plot.linestyle_dotted)


