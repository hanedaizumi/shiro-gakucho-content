//@version=6
indicator("Trend Gazer v999 : Enhanced with EMA State Management", 
     shorttitle="TrendGazer999", 
     overlay=true, 
     max_bars_back=1500,
     max_lines_count=100,
     max_labels_count=500,
     max_boxes_count=100,
     dynamic_requests=true)

import TradingView/ta/10 as tvta

bool is1minChart = timeframe.period == "1"
bool is5minChart = timeframe.period == "5"
bool is15minChart = timeframe.period == "15"
bool is1HourChart = timeframe.period == "60"
bool is_15m_or_higher = timeframe.in_seconds("") >= 900
bool is_30m_or_higher = timeframe.in_seconds("") >= 1800
bool is_1hr_or_higher = false
bool is_4hr_or_higher = false
bool is_1day_or_higher = false

bool hide_npr_bb_on_4hr = timeframe.in_seconds("") >= 14400

rsiBullCol = color.red
rsiBearCol = color.blue

grpEMA200Signals = "═══ EMA200 Signal Selection ═══"
useEMA200Long5 = input.bool(false, "Use EMA200 LONG #5", group=grpEMA200Signals, tooltip="DEFAULT OFF | Inst.Det based")
useEMA200Short5 = input.bool(false, "Use EMA200 SHORT #5", group=grpEMA200Signals, tooltip="DEFAULT OFF | Inst.Det based")
use60mEMA200Long5 = input.bool(false, "Use 60m EMA200 LONG #5", group=grpEMA200Signals, tooltip="DEFAULT OFF | Inst.Det based")
use60mEMA200Short5 = input.bool(false, "Use 60m EMA200 SHORT #5", group=grpEMA200Signals, tooltip="DEFAULT OFF | Inst.Det based")
useEMA200Long6 = input.bool(false, "Use EMA200 LONG #6", group=grpEMA200Signals, tooltip="DEFAULT OFF | 2 consecutive Inst.Det")
useEMA200Short6 = input.bool(false, "Use EMA200 SHORT #6", group=grpEMA200Signals, tooltip="DEFAULT OFF | 2 consecutive Inst.Det")
useEMA200Long7 = input.bool(true, "⭐ Use EMA200 LONG #7", group=grpEMA200Signals, tooltip="⭐ DEFAULT ON | Display when: 1) Close crossed over EMA200/100/50, then 2) EMA20 > EMA50 > EMA100 order achieved.")
useEMA200Short7 = input.bool(true, "⭐ Use EMA200 SHORT #7", group=grpEMA200Signals, tooltip="⭐ DEFAULT ON | Display when: 1) Close crossed under EMA200/100/50, then 2) EMA20 < EMA50 < EMA100 order achieved.")
alternateEMA200_7 = input.bool(false, "Alternate EMA200 #7 Display", group=grpEMA200Signals, tooltip="DEFAULT OFF | EMA200 LONG#7 and SHORT#7 alternate display. After LONG#7 is shown, SHORT#7 won't display until LONG#7 appears again, and vice versa.")
showEMA200LongShort = input.bool(true, "Show EMA200 LONG/SHORT Labels", group=grpEMA200Signals, tooltip="DEFAULT ON | When disabled, all EMA200 LONG and SHORT labels (#5, #6, #7, 60m, MTF) are hidden.")

grpVWAP = "═══ VWAP Settings ═══"
hideVWAPonDWM = input.bool(false, "Hide VWAP on 1D or Above", group=grpVWAP, tooltip="When true, VWAP is not calculated on daily or higher timeframes.")
vwapAnchor = input.string("Session", "VWAP Anchor Period", options=["Session", "Week", "Month", "Quarter", "Year", "Decade", "Century"], group=grpVWAP)
useVWAPLong = input.bool(true, "⭐ Use VWAP LONG", group=grpVWAP, tooltip="Display VWAP LONG when price crosses above VWAP and VWAP slope is positive.")
useVWAPShort = input.bool(true, "⭐ Use VWAP SHORT", group=grpVWAP, tooltip="Display VWAP SHORT when price crosses below VWAP and VWAP slope is negative.")

bool useEMA50Long5 = false
bool useEMA50Short5 = false
bool use60mEMA50Long5 = false
bool use60mEMA50Short5 = false

grpFilters = "═══ Signal Filters ═══"
showLongShortLabels = input.bool(true, "Show LONG/SHORT Labels", group=grpFilters, tooltip="DEFAULT ON | Display LONG/SHORT labels (BUY#1, BUY#2, SELL#1, SELL#2). Note: RBB LONG/SHORT labels are controlled separately.")
showOnlyEMA200_7 = input.bool(false, "🎯 Show ONLY EMA200 #7 Labels", group=grpFilters, tooltip="DEFAULT OFF | When enabled, displays ONLY EMA200 LONG#7 and SHORT#7 labels. All other labels (BUY/SELL #1/#2, ST, EMA200 #5, etc.) are hidden.")
showOnlyVWAPLongShort = input.bool(false, "🎯 Show ONLY VWAP LONG/SHORT #2 Labels", group=grpFilters, tooltip="DEFAULT OFF | When enabled, displays ONLY VWAP LONG#2 and VWAP SHORT#2 labels. All other labels are hidden.")
enableAlternatingDisplay = input.bool(false, "⭐ Enable Alternating BUY/SELL Display", group=grpFilters, tooltip="⭐ DEFAULT OFF | Must BUY is hidden until Must SELL appears, and vice versa. Prevents consecutive BUY or SELL labels. When OFF, all labels are displayed.")
enableBonusFilter = input.bool(true, "⭐ 💲 Enable Bonus Filter: Premium Entry Detector (Recommended)", group=grpFilters, tooltip="⭐ DEFAULT ON | SELL: High ≥ VAH. BUY: Low ≤ VAL. Applied FIRST. Bonus signals: 💲 prefix, BLACK background, EXEMPT from Advanced Filters. Final Filters 2/4/5/6 are APPLIED to Bonus signals.")
enableFinalFilter3 = input.bool(false, "Enable Final Filter 3: Volume Profile POC Filter", group=grpFilters, tooltip="DEFAULT OFF | BUY signals only when Low ≤ POC. SELL signals only when High ≥ POC. Applied LAST after all other filters.")
enableFinalFilter2 = input.bool(false, "Enable Final Filter 2: Reversal BB Trend Filter", group=grpFilters, tooltip="DEFAULT OFF | When Reversal BB is LIME (downtrend, close < basis) → SELL only. When Reversal BB is RED (uptrend, close > basis) → BUY only. Applies to ALL signals.")
enableUltimateFilter = input.bool(true, "⭐ Enable Ultimate Filter: Multi-Confluence Filter", group=grpFilters, tooltip="⭐ DEFAULT ON | Combines 60m NPR/BB and EMA7/20 cross for high-probability entries. BUY/LONG: Lower NPR OR Lower BB OR bull flag (EMA7>20). SELL/SHORT: Upper NPR OR Upper BB OR bear flag (EMA7<20).")
enableLiquidationFilter = input.bool(false, "Enable Filter 0: Liquidation Reversal Filter", group=grpFilters, tooltip="DEFAULT OFF | When bar is Red (Bullish Reversal), show BUY signals only. When bar is Blue (Bearish Reversal), show SELL signals only. Uses Up/Down volume Z-scores and Supertrend to detect liquidation spikes.")
enableICTFilter = input.bool(false, "Enable ICT Market Structure Filter", group=grpFilters, tooltip="DEFAULT OFF | Show BUY/SELL ONLY after Market Structure (CHoCH/SiMS/BoMS). All MS-triggered signals are LARGE with WHITE text. All other signals are hidden. After (𝟏) CHoCH → BUY only. After (𝐚) CHoCH → SELL only.")
enableEMAFilter = input.bool(false, "Enable EMA Trend Filter", group=grpFilters, tooltip="DEFAULT OFF | Block BUY when EMA50<100<200<400<800 (perfect bearish). Block SELL when EMA50>100>200>400>800 (perfect bullish). Exception: Allows signals when 60%+ OB is generated.")
enableEMA200AngleFilter = input.bool(true, "⭐ Enable EMA200 Angle Acceleration Filter", group=grpFilters, tooltip="⭐ DEFAULT ON | BUY/LONG signals only when EMA200 angle is INCREASING (accelerating upward). SELL/SHORT signals only when EMA200 angle is DECREASING (accelerating downward). Angle = 0 when slope is flat, positive when rising, negative when falling.")
enableRBBColorFilter = input.bool(true, "⭐ Enable RBB Color Filter", group=grpFilters, tooltip="⭐ DEFAULT ON | When RBB Fill = RED: Show only BUY/LONG labels. When RBB Fill = PINE: Show only SELL/SHORT labels.")
enableEMA200NPRFilter = input.bool(false, "Enable EMA200 NPR Touch Filter", group=grpFilters, tooltip="DEFAULT OFF | Hide EMA200 LONG labels when bar's BODY (not wick) touches 60m Upper NPR. Hide EMA200 SHORT labels when bar's BODY (not wick) touches 60m Lower NPR. Applies to all EMA200 signals (own timeframe + MTF).")
enableNPROutsideFilter = input.bool(false, "Enable NPR Outside Filter", group=grpFilters, tooltip="DEFAULT OFF (Strategy: DEFAULT ON) | Hide ALL labels (BUY/SELL/LONG/SHORT, own + MTF) when price wick touches or goes outside 60m NPR range. Upper NPR touch/breach → hide all. Lower NPR touch/breach → hide all.")
enableMTFEMA200BBFilter = input.bool(false, "Enable MTF 60min EMA200/BB Trend Filter", group=grpFilters, tooltip="DEFAULT OFF | Hide all labels when bar touches 60m EMA200. Below EMA200: show only SELL/SHORT if lower BB slope is negative, only BUY/LONG if positive. Above EMA200: show only SELL/SHORT if upper BB slope is negative, only BUY/LONG if positive.")
enableAlternatingAllLabels = input.bool(false, "Enable Alternating All Labels Filter", group=grpFilters, tooltip="DEFAULT OFF | After LONG/BUY label (own + MTF), hide all LONG/BUY labels until SHORT/SELL appears. After SHORT/SELL label (own + MTF), hide all SHORT/SELL labels until LONG/BUY appears. Prevents consecutive same-direction signals.")
enableCrownOnlyFilter = input.bool(false, "⭐ Enable Crown Only Filter (EMA200 Cross)", group=grpFilters, tooltip="⭐ DEFAULT OFF | Show only labels with 👑👑 double crown mark. Double crown is added to FIRST BUY/LONG label after EMA200/MTF60 EMA200/NPR/BB crossover (price crosses above or bounces up from touch), and FIRST SELL/SHORT label after crossunder (price crosses below or bounces down from touch).")
enableEMA200_5OnlyFilter = input.bool(false, "🎯 Enable EMA200 #5 Only Filter", group=grpFilters, tooltip="DEFAULT OFF | Show only EMA200 LONG/SHORT #5 and 60m EMA200 LONG/SHORT #5 labels. All other labels will be hidden.")
enableEMA50_EMA200Filter = input.bool(true, "⭐ Enable EMA50 EMA200 Position Filter", group=grpFilters, tooltip="⭐ DEFAULT ON | For EMA50 LONG/SHORT #5 and 60m EMA50 LONG/SHORT #5 only: LONG when bar HIGH ≥ EMA200, SHORT when bar LOW ≤ EMA200.")
enableEMA50_100_200OrderFilter = input.bool(true, "⭐ Enable EMA50/100/200 Order Filter", group=grpFilters, tooltip="⭐ DEFAULT ON | Hide BUY/LONG labels when EMA50 < EMA200 & EMA100 < EMA200. Hide SELL/SHORT labels when EMA50 > EMA200 & EMA100 > EMA200. Applies to ALL labels and ANY alerts.")
enableEMAConvergenceFilter = input.bool(true, "⭐ Enable EMA Convergence Filter", group=grpFilters, tooltip="⭐ DEFAULT ON | Show labels only when EMAs are gradually converging (Purple background). 4本EMA(20/50/100/200) or 3本EMA(20/50/100). Based on EMA standard deviation convergence detection.")

grpConvergence = "EMA Convergence Filter Settings"
use_4ema_convergence = input.bool(true, "⭐ Use 4-EMA Convergence (20/50/100/200)", group=grpConvergence, tooltip="⭐ DEFAULT ON | Use 4-EMA (20/50/100/200) convergence detection. Darker purple background (90% transparency).")
use_3ema_convergence = input.bool(false, "Use 3-EMA Convergence (20/50/100)", group=grpConvergence, tooltip="DEFAULT OFF | Use 3-EMA (20/50/100) convergence detection. Lighter purple background (95% transparency).")
convergence_threshold = input.float(0.4, "収束閾値 (%)", minval=0.1, maxval=5.0, step=0.1, group=grpConvergence,
     tooltip="EMA標準偏差が平均値の何%以下で収束と判定するか")
convergence_bars = input.int(5, "収束期間 (バー)", minval=5, maxval=30, group=grpConvergence,
     tooltip="何バーかけてゆっくり収束していることを確認するか")
show_convergence_bg = input.bool(false, "Show Convergence Background", group=grpConvergence, tooltip="DEFAULT OFF | Display purple background when EMAs are gradually converging (4本EMA or 3本EMA)")

