bool mtf_15m_changed = curr_div_15m_state != prev_div_15m_state and curr_div_15m_state != 0
bool mtf_1h_changed = curr_div_1h_state != prev_div_1h_state and curr_div_1h_state != 0
bool mtf_4h_changed = curr_div_4h_state != prev_div_4h_state and curr_div_4h_state != 0

if showMTFChangeLabels
    if mtf_5m_changed or mtf_15m_changed or mtf_1h_changed or mtf_4h_changed
        string prefix_4h = mtf_4h_changed ? "★" : "  "
        string prefix_1h = mtf_1h_changed ? "★" : "  "
        string prefix_15m = mtf_15m_changed ? "★" : "  "
        string prefix_05m = mtf_5m_changed ? "★" : "  "
        
        string line_4h = prefix_4h + "4H " + (curr_div_4h_state > 0 ? "UP" : (curr_div_4h_state < 0 ? "DOWN" : "---"))
        string line_1h = prefix_1h + "1H " + (curr_div_1h_state > 0 ? "UP" : (curr_div_1h_state < 0 ? "DOWN" : "---"))
        string line_15m = prefix_15m + "15m " + (curr_div_15m_state > 0 ? "UP" : (curr_div_15m_state < 0 ? "DOWN" : "---"))
        string line_05m = prefix_05m + "05m " + (curr_div_5m_state > 0 ? "UP" : (curr_div_5m_state < 0 ? "DOWN" : "---"))
        
        string mtf_text = line_4h + "\n" + line_1h + "\n" + line_15m + "\n" + line_05m
        
        bool is_up_trend = mtf_4h_changed ? (curr_div_4h_state > 0) : (mtf_1h_changed ? (curr_div_1h_state > 0) : (mtf_15m_changed ? (curr_div_15m_state > 0) : (curr_div_5m_state > 0)))
        
        float mtf_label_offset = ta.atr(14) * 2.5
        float label_y = is_up_trend ? low - mtf_label_offset : high + mtf_label_offset
        label.new(bar_index, label_y, text=mtf_text, style=is_up_trend ? label.style_label_up : label.style_label_down, size=size.small, color=color.new(color.white, 20), textcolor=color.gray)
























int mtf_status_down_count = (curr_div_4h_state < 0 ? 1 : 0) + (curr_div_1h_state < 0 ? 1 : 0) + (curr_div_15m_state < 0 ? 1 : 0) + (curr_div_5m_state < 0 ? 1 : 0)
int mtf_status_up_count = (curr_div_4h_state > 0 ? 1 : 0) + (curr_div_1h_state > 0 ? 1 : 0) + (curr_div_15m_state > 0 ? 1 : 0) + (curr_div_5m_state > 0 ? 1 : 0)





prev_div_5m_state := curr_div_5m_state
prev_div_15m_state := curr_div_15m_state
prev_div_1h_state := curr_div_1h_state
prev_div_4h_state := curr_div_4h_state
prev_div_1d_state := curr_div_1d_state

alertcondition(rbb_bullish_condition, 
               title="🔴 Reversal BB: BUY (RED)", 
               message="[RBB] BUY {{interval}}m {{ticker}}")

alertcondition(rbb_bearish_condition, 
               title="🟢 Reversal BB: SELL (GREEN)", 
               message="[RBB] SELL {{interval}}m {{ticker}}")


bool crown_buy_long_detected = ema200_crossover_detected or mtf60_ema200_crossover_detected or mtf60_npr_lower_crossover_detected or mtf60_bb_lower_crossover_detected

bool crown_sell_short_detected = ema200_crossunder_detected or mtf60_ema200_crossunder_detected or mtf60_npr_upper_crossunder_detected or mtf60_bb_upper_crossunder_detected

bool tier1_condition = (touching_upper_band or touching_lower_band or touching_ema50) and (bullish_candle or bearish_candle)


float label_atr_offset = ta.atr(14)


bool ema20_block_long = false
bool ema20_block_short = false


if buy_label_displayed
    alert("LONG " + timeframe.period + "m " + syminfo.ticker, alert.freq_once_per_bar)
else if sell_label_displayed
    alert("SHORT " + timeframe.period + "m " + syminfo.ticker, alert.freq_once_per_bar)












[st_1d, stTrend_1d, rbb_1d_uptrend, ema20_1d, ema50_1d] = request.security(syminfo.tickerid, "1D", [supertrend, stTrend, close > rbb_basis, ema20, ema50])
[st_4h, stTrend_4h, rbb_4h_uptrend, ema20_4h, ema50_4h] = request.security(syminfo.tickerid, "240", [supertrend, stTrend, close > rbb_basis, ema20, ema50])
[st_1h, stTrend_1h, rbb_1h_uptrend, ema20_1h, ema50_1h] = request.security(syminfo.tickerid, "60", [supertrend, stTrend, close > rbb_basis, ema20, ema50])
[st_15m, stTrend_15m, rbb_15m_uptrend, ema7_15m_tmp, ema20_15m_tmp, ema50_15m_tmp, ema100_15m_tmp] = request.security(syminfo.tickerid, "15", [supertrend, stTrend, close > rbb_basis, ema7, ema20, ema50, ema100])
ema7_15m := ema7_15m_tmp
ema20_15m := ema20_15m_tmp
ema50_15m := ema50_15m_tmp
ema100_15m := ema100_15m_tmp
