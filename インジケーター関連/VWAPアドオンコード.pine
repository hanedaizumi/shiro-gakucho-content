if false
    label.new(bar_index, low - aggressive_label_atr_offset * 0.75, 
              text="🌟Strong BUY\nVertical", 
              style=label.style_label_up, 
              size=size.small, 
              color=color.new(color.green, 20), 
              textcolor=color.white)
    
