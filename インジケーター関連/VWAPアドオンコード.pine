    if both_nprs_green and not na(npr60m_lower)
        if low <= npr60m_lower
            npr_buy_priority := true

bool npr_sell_priority = false
if bearish_candle
    if both_nprs_green and not na(npr60m_lower) and not na(npr60m_upper)
        if high >= npr60m_upper or low <= npr60m_lower
            npr_sell_priority := true
    if both_nprs_red and not na(npr60m_upper)
        if high >= npr60m_upper
            npr_sell_priority := true

bool ema50_buy_priority = false
