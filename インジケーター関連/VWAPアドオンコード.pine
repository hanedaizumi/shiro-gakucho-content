    bool ema50_touched = low <= ema50 and high >= ema50
    if ema50_touched
        if both_nprs_red
            ema50_buy_priority := true
        if not both_nprs_red and not both_nprs_green
            ema50_buy_priority := true

bool ema50_sell_priority = false
if bearish_candle and not na(ema50)
    bool ema50_touched = low <= ema50 and high >= ema50
    if ema50_touched
        if both_nprs_green
            ema50_sell_priority := true
        if not both_nprs_red and not both_nprs_green
            ema50_sell_priority := true




















