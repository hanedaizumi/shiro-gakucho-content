ema400 = not is_4hr_or_higher ? ta.ema(close, ema400_length) : close
ema800 = not is_4hr_or_higher ? ta.ema(close, ema800_length) : close

bool vwapIsNewPeriod = switch vwapAnchor
    "Session"   => timeframe.change("D")
    "Week"      => timeframe.change("W")
    "Month"     => timeframe.change("M")
    "Quarter"   => timeframe.change("3M")
    "Year"      => timeframe.change("12M")
    "Decade"    => timeframe.change("12M") and year % 10 == 0
    "Century"   => timeframe.change("12M") and year % 100 == 0
    => false

float vwapValue = na
float vwap5m = request.security(syminfo.tickerid, "5", ta.vwap(hlc3, vwapAnchor == "Session" ? timeframe.change("D") : vwapAnchor == "Week" ? timeframe.change("W") : vwapAnchor == "Month" ? timeframe.change("M") : vwapAnchor == "Quarter" ? timeframe.change("3M") : vwapAnchor == "Year" ? timeframe.change("12M") : vwapAnchor == "Decade" ? (timeframe.change("12M") and year % 10 == 0) : (timeframe.change("12M") and year % 100 == 0)), barmerge.gaps_off, barmerge.lookahead_off)
if is1minChart
    vwapValue := vwap5m
else if not (hideVWAPonDWM and timeframe.isdwm)
    vwapValue := ta.vwap(hlc3, vwapIsNewPeriod)

vwma_bb_basis = request.security(syminfo.tickerid, vwma_bb_timeframe, ta.vwma(vwma_bb_source, vwma_bb_length))
vwma_bb_stdev = request.security(syminfo.tickerid, vwma_bb_timeframe, ta.stdev(vwma_bb_source, vwma_bb_length))

vwma_bb_dev1 = vwma_bb_mult1 * vwma_bb_stdev
vwma_bb_dev2 = vwma_bb_mult2 * vwma_bb_stdev
vwma_bb_dev3 = vwma_bb_mult3 * vwma_bb_stdev

vwma_bb_upper1 = vwma_bb_basis + vwma_bb_dev1
vwma_bb_lower1 = vwma_bb_basis - vwma_bb_dev1
vwma_bb_upper2 = vwma_bb_basis + vwma_bb_dev2
vwma_bb_lower2 = vwma_bb_basis - vwma_bb_dev2
vwma_bb_upper3 = vwma_bb_basis + vwma_bb_dev3
vwma_bb_lower3 = vwma_bb_basis - vwma_bb_dev3

var int trend_state = 1

bool ema_bullish_align = ema20 > ema50 and ema20 > ema100
bool ema_bearish_align = ema20 < ema50 and ema20 < ema100

if trend_state == 1
    if ema_bearish_align
        trend_state := 4

else if trend_state == 2
    if ema_bearish_align
        trend_state := 3

else if trend_state == 3
    if ema_bullish_align
        trend_state := 2

else if trend_state == 4
    if ema_bullish_align
        trend_state := 1

string ema_state = ""
color  ema_bgCol = na
color  ema_labelCol = color.new(color.gray, 60)
color  ema_textCol = color.white

if trend_state == 1
    ema_state := "強気１ ↑"
    ema_bgCol := color.new(color.red, 70)
    ema_labelCol := color.new(color.red, 60)
    ema_textCol := color.white
else if trend_state == 2
    ema_state := "強気２ ↗"
    ema_bgCol := color.new(color.red, 70)
    ema_labelCol := color.new(color.red, 60)
    ema_textCol := color.white
else if trend_state == 3
    ema_state := "弱気１ ↓"
    ema_bgCol := color.new(color.green, 70)
    ema_labelCol := color.new(color.green, 60)
    ema_textCol := color.black
else if trend_state == 4
    ema_state := "弱気２ ↘"
    ema_bgCol := color.new(color.green, 70)
    ema_labelCol := color.new(color.green, 60)
    ema_textCol := color.black


ema_avg = (ema20 + ema50 + ema100 + ema200) / 4

ema_variance = (math.pow(ema20 - ema_avg, 2) + math.pow(ema50 - ema_avg, 2) + math.pow(ema100 - ema_avg, 2) + math.pow(ema200 - ema_avg, 2)) / 4

ema_std = math.sqrt(ema_variance)

std_ratio = ema_std / ema_avg * 100

is_converged_now = std_ratio < convergence_threshold

std_decrease_speed = (std_ratio[convergence_bars] - std_ratio) / convergence_bars

is_gradual_convergence = std_decrease_speed > 0 and std_decrease_speed < 0.3 and is_converged_now

var float convergence_detected_bar = na
if is_gradual_convergence and na(convergence_detected_bar)
    convergence_detected_bar := bar_index

if is_converged_now and na(convergence_detected_bar)
    convergence_detected_bar := bar_index

ema_avg_3 = (ema20 + ema50 + ema100) / 3

ema_variance_3 = (math.pow(ema20 - ema_avg_3, 2) + math.pow(ema50 - ema_avg_3, 2) + math.pow(ema100 - ema_avg_3, 2)) / 3

ema_std_3 = math.sqrt(ema_variance_3)

std_ratio_3 = ema_std_3 / ema_avg_3 * 100

is_converged_now_3 = std_ratio_3 < convergence_threshold

std_decrease_speed_3 = (std_ratio_3[convergence_bars] - std_ratio_3) / convergence_bars

is_gradual_convergence_3 = std_decrease_speed_3 > 0 and std_decrease_speed_3 < 0.3 and is_converged_now_3

var float convergence_detected_bar_3 = na
if is_gradual_convergence_3 and na(convergence_detected_bar_3)
    convergence_detected_bar_3 := bar_index

if is_converged_now_3 and na(convergence_detected_bar_3)
    convergence_detected_bar_3 := bar_index

bool ema_4_active = use_4ema_convergence and is_gradual_convergence
bool ema_3_active = use_3ema_convergence and is_gradual_convergence_3
ema_convergence_filter_pass = not enableEMAConvergenceFilter or ema_4_active or ema_3_active

bool ema_order_allow_long = not enableEMA50_100_200OrderFilter or not (ema50 < ema200 and ema100 < ema200)
bool ema_order_allow_short = not enableEMA50_100_200OrderFilter or not (ema50 > ema200 and ema100 > ema200)

calcSuperTrend(atrLen, multiplier) =>
    atrValue = ta.atr(atrLen)
    hl2Val = (high + low) / 2
    basic_ub = hl2Val + (atrValue * multiplier)
    basic_lb = hl2Val - (atrValue * multiplier)
    
    var float final_ub = na
    var float final_lb = na
    
    final_ub := na(final_ub[1]) ? basic_ub : (basic_ub < final_ub[1] or close[1] > final_ub[1]) ? basic_ub : final_ub[1]
    final_lb := na(final_lb[1]) ? basic_lb : (basic_lb > final_lb[1] or close[1] < final_lb[1]) ? basic_lb : final_lb[1]
    
    var float st = na
    
    if na(st[1])
        st := final_ub
    else
        if st[1] == final_ub[1]
            st := close <= final_ub ? final_ub : final_lb
        else if st[1] == final_lb[1]
            st := close >= final_lb ? final_lb : final_ub
        else
            st := close <= final_ub ? final_ub : final_lb
    
    trend_dir = st == final_lb ? 1 : -1
    [st, trend_dir]

[supertrend, stTrend] = calcSuperTrend(stAtrPeriod, stFactor)

bool stBuySignal = enableSupertrend and stTrend == 1 and stTrend[1] == -1 and st_trend_up_flag and (not enableSTAlternatingDisplay or not st_buy_flag) and ema_convergence_filter_pass and ema_order_allow_long
bool stSellSignal = enableSupertrend and stTrend == -1 and stTrend[1] == 1 and st_trend_down_flag and (not enableSTAlternatingDisplay or not st_sell_flag) and ema_convergence_filter_pass and ema_order_allow_short

bool ema200_crossover_detected = (low[1] < ema200[1]) and (high >= ema200)

bool ema200_crossunder_detected = (high[1] > ema200[1]) and (low <= ema200)

if ema200_crossover_detected
    ema200_crown_crossover_flag := true
    ema200_crown_crossunder_flag := false
else if ema200_crossunder_detected
    ema200_crown_crossunder_flag := true
    ema200_crown_crossover_flag := false

float ema20_divergence = ((ema20 - ema200) / ema200) * 100
float ema50_divergence = ((ema50 - ema200) / ema200) * 100
float ema100_divergence = ((ema100 - ema200) / ema200) * 100

float ema_convergence_index = (ema20_divergence + ema50_divergence + ema100_divergence) / 3

float ema_convergence_abs = math.abs(ema_convergence_index)

float ema200_slope = ema200 - ema200[1]
float ema50_slope = ema50 - ema50[1]
float ema100_slope = ema100 - ema100[1]
bool ema50_100_slope_both_positive = ema50_slope > 0 and ema100_slope > 0
bool ema50_100_slope_both_negative = ema50_slope < 0 and ema100_slope < 0

float ema200_angle = math.atan(ema200_slope / close) * (180 / math.pi)

var float ema200_prev_angle = na

float ema200_angle_acceleration = na
if not na(ema200_prev_angle)
    ema200_angle_acceleration := ema200_angle - ema200_prev_angle

ema200_prev_angle := ema200_angle

bool ema200_angle_increasing = not na(ema200_angle_acceleration) and ema200_angle_acceleration > 0
bool ema200_angle_decreasing = not na(ema200_angle_acceleration) and ema200_angle_acceleration < 0

var bool mytime_trend_up_flag = false
var bool mytime_trend_down_flag = false

var bool npr_upper_crossed_down = false
var bool npr_lower_crossed_up = false
var bool first_ema200_long_after_npr_displayed = false
var bool first_ema200_short_after_npr_displayed = false
var bool first_buy_after_npr_displayed = false
var bool first_sell_after_npr_displayed = false

var bool bb_upper_crossed_down = false
var bool bb_lower_crossed_up = false
var bool first_ema200_long_after_bb_displayed = false
var bool first_ema200_short_after_bb_displayed = false
var bool first_buy_after_bb_displayed = false
var bool first_sell_after_bb_displayed = false

var bool first_buy_long_after_rbb_red_displayed = false
var bool first_sell_short_after_rbb_pine_displayed = false

bool ema_bullish_order = ema20 > ema50 and ema50 > ema100 and ema100 > ema200
bool ema_bearish_order = ema20 < ema50 and ema50 < ema100 and ema100 < ema200

float npr_60m_high_sma = request.security(syminfo.tickerid, "60", ta.sma(high, 20), barmerge.gaps_off, barmerge.lookahead_off)
float npr_60m_low_sma = request.security(syminfo.tickerid, "60", ta.sma(low, 20), barmerge.gaps_off, barmerge.lookahead_off)
float npr_60m_atr = request.security(syminfo.tickerid, "60", ta.atr(14), barmerge.gaps_off, barmerge.lookahead_off)

float npr_60m_upper = npr_60m_high_sma + npr_60m_atr * 0.5
float npr_60m_lower = npr_60m_low_sma - npr_60m_atr * 0.5

bool npr_upper_crossunder = (high >= npr_60m_upper or high[1] >= npr_60m_upper) and close < npr_60m_upper
bool npr_lower_crossover = (low <= npr_60m_lower or low[1] <= npr_60m_lower) and close > npr_60m_lower

if npr_upper_crossunder
    npr_upper_crossed_down := true
    first_ema200_long_after_npr_displayed := false
    first_buy_after_npr_displayed := false

if npr_lower_crossover
    npr_lower_crossed_up := true
    first_ema200_short_after_npr_displayed := false
    first_sell_after_npr_displayed := false

if high >= npr_60m_upper or low <= npr_60m_upper
    npr_upper_crossed_down := false
    first_ema200_long_after_npr_displayed := false
    first_buy_after_npr_displayed := false

if low <= npr_60m_lower or high >= npr_60m_lower
    npr_lower_crossed_up := false
    first_ema200_short_after_npr_displayed := false
    first_sell_after_npr_displayed := false

bool allow_buy_label_current = true
bool allow_sell_label_current = true
bool allow_ema200_long_label_current = true
bool allow_ema200_short_label_current = true

if not ema_convergence_filter_pass
    allow_buy_label_current := false
    allow_sell_label_current := false
    allow_ema200_long_label_current := false
    allow_ema200_short_label_current := false

if ema_bullish_order
    allow_sell_label_current := false
    allow_ema200_short_label_current := false
    if enableNPRException1 and npr_upper_crossed_down and not first_ema200_long_after_npr_displayed
        allow_ema200_long_label_current := true
    if enableNPRException2 and npr_upper_crossed_down and not first_buy_after_npr_displayed
        allow_buy_label_current := true
    if enableBBException3 and bb_upper_crossed_down and not first_ema200_long_after_bb_displayed
        allow_ema200_long_label_current := true
    if enableBBException4 and bb_upper_crossed_down and not first_buy_after_bb_displayed
        allow_buy_label_current := true

if ema_bearish_order
    allow_buy_label_current := false
    allow_ema200_long_label_current := false
    if enableNPRException1 and npr_lower_crossed_up and not first_ema200_short_after_npr_displayed
        allow_ema200_short_label_current := true
    if enableNPRException2 and npr_lower_crossed_up and not first_sell_after_npr_displayed
        allow_sell_label_current := true
    if enableBBException3 and bb_lower_crossed_up and not first_ema200_short_after_bb_displayed
        allow_ema200_short_label_current := true
    if enableBBException4 and bb_lower_crossed_up and not first_sell_after_bb_displayed
        allow_sell_label_current := true

if enableCrownOnlyFilter
    bool any_crossover_flag = ema200_crown_crossover_flag or mtf60_ema200_crown_crossover_flag or mtf60_npr_lower_crown_crossover_flag or mtf60_bb_lower_crown_crossover_flag
    if not any_crossover_flag
        allow_buy_label_current := false
        allow_ema200_long_label_current := false
    bool any_crossunder_flag = ema200_crown_crossunder_flag or mtf60_ema200_crown_crossunder_flag or mtf60_npr_upper_crown_crossunder_flag or mtf60_bb_upper_crown_crossunder_flag
    if not any_crossunder_flag
        allow_sell_label_current := false
        allow_ema200_short_label_current := false

if is1minChart
    if mytime_trend_up_flag
        allow_buy_label_current := true
        allow_ema200_long_label_current := true
    
    if mytime_trend_down_flag
        allow_sell_label_current := true
        allow_ema200_short_label_current := true

var float prev_abs = na
var float prev_prev_abs = na
var float prev_index = na

bool abs_decreasing_phase = not na(prev_prev_abs) and not na(prev_abs) and prev_prev_abs > prev_abs
bool abs_increasing_phase = not na(prev_abs) and ema_convergence_abs > prev_abs
bool at_turning_point = abs_decreasing_phase and abs_increasing_phase

bool diverging_positive = at_turning_point and ema_convergence_index > 0 and (na(prev_index) or ema_convergence_index > prev_index)
bool diverging_negative = at_turning_point and ema_convergence_index < 0 and (na(prev_index) or ema_convergence_index < prev_index)

prev_prev_abs := prev_abs
prev_abs := ema_convergence_abs
prev_index := ema_convergence_index

bool ema50_crossover_touch = (ta.crossover(close, ema50) or (low <= ema50 and close > ema50))
bool ema100_crossover_touch = (ta.crossover(close, ema100) or (low <= ema100 and close > ema100))
bool ema200_crossover_touch = (ta.crossover(close, ema200) or (low <= ema200 and close > ema200))

bool ema50_crossunder_touch = (ta.crossunder(close, ema50) or (high >= ema50 and close < ema50))
bool ema100_crossunder_touch = (ta.crossunder(close, ema100) or (high >= ema100 and close < ema100))
bool ema200_crossunder_touch = (ta.crossunder(close, ema200) or (high >= ema200 and close < ema200))

bool any_ema_crossover = ema50_crossover_touch or ema100_crossover_touch or ema200_crossover_touch
bool any_ema_crossunder = ema50_crossunder_touch or ema100_crossunder_touch or ema200_crossunder_touch

var bool waiting_for_buy_divergence = false
var bool waiting_for_sell_divergence = false

var bool ema200_crossover_3_flag = false
var bool ema200_crossunder_3_flag = false

var bool ema200_60m_trend_up_flag = false
var bool ema200_60m_trend_down_flag = false
var bool ema200_60m_BUY_activated_flag = false
var bool ema200_60m_SELL_activated_flag = false
var bool ema200_60m_crossover_completed_flag = false
var bool ema200_60m_crossunder_completed_flag = false
var bool ema200_60m_rebound_up_flag = false
var bool ema200_60m_rebound_down_flag = false
var int ema200_60m_rebound_up_count = 0
var int ema200_60m_rebound_down_count = 0
var int ema200_60m_rebound_up_bar = na
var int ema200_60m_rebound_down_bar = na
var int ema200_60m_crossover_bar = -999
var int ema200_60m_crossunder_bar = -999
var int ema200_60m_crossover_completed_bar = na
var int ema200_60m_crossunder_completed_bar = na
var bool ema200_60m_ema20_ema50_trend_up_flag = false
var bool ema200_60m_ema20_ema50_trend_down_flag = false

var int ema200_long1_display_count = 0
var int ema200_long2_display_count = 0
var int ema200_long3_display_count = 0
var int ema200_long4_display_count = 0
var int ema200_short1_display_count = 0
var int ema200_short2_display_count = 0
var int ema200_short3_display_count = 0
var int ema200_short4_display_count = 0

if ema200_crossover_touch
    ema200_crossover_3_flag := true
    ema200_crossunder_3_flag := false
    ema200_long1_display_count := 0
    ema200_long2_display_count := 0
    ema200_long3_display_count := 0
    ema200_long4_display_count := 0

if ema200_crossunder_touch
    ema200_crossunder_3_flag := true
    ema200_crossover_3_flag := false
    ema200_short1_display_count := 0
    ema200_short2_display_count := 0
    ema200_short3_display_count := 0
    ema200_short4_display_count := 0

if any_ema_crossover
    waiting_for_buy_divergence := true

if any_ema_crossunder
    waiting_for_sell_divergence := true

bool diverging_positive_filtered = diverging_positive and waiting_for_buy_divergence
bool diverging_negative_filtered = diverging_negative and waiting_for_sell_divergence


vol = volume
volMA = ta.sma(vol, institutionalLookback)
volStd = ta.stdev(vol, institutionalLookback)
zScore = volStd > 0 ? (vol - volMA) / volStd : 0

priceChange = (close - close[1]) / close[1]
priceChangeAbs = math.abs(priceChange)

isAggressive = enableInstitutionalDetection and zScore > institutionalVolumeThreshold and priceChangeAbs > institutionalPriceChangeThreshold * 3
aggressiveDir = priceChange > 0 ? 1 : -1

isAbsorption = detectAbsorption and zScore > institutionalVolumeThreshold and priceChangeAbs < institutionalPriceChangeThreshold
absorptionDir = 0

consecutiveHighVol = true
if detectIceberg
    for i = 1 to 1
        if zScore[i] < 1.5
            consecutiveHighVol := false
            break

isIceberg = detectIceberg and zScore > institutionalVolumeThreshold and consecutiveHighVol
icebergDir = (close - low) / (high - low) > 0.6 ? 1 : -1

if isAggressive and aggressiveDir > 0
    Aggressive_Positive_Flag := true
    Aggressive_Negative_Flag := false

if isAggressive and aggressiveDir < 0
    Aggressive_Negative_Flag := true
    Aggressive_Positive_Flag := false

bool detected = isAggressive or isAbsorption or isIceberg

int orderDirection = isAggressive ? aggressiveDir : isAbsorption ? absorptionDir : isIceberg ? icebergDir : 0

color inst_bg_color = na
if showInstitutionalBg and detected
    if isIceberg
        inst_bg_color := orderDirection > 0 ? color.new(color.red, 70) : color.new(color.lime, 70)
    else
        inst_bg_color := orderDirection > 0 ? color.new(color.red, 70) : orderDirection < 0 ? color.new(color.lime, 70) : color.new(color.gray, 70)
    
    if orderDirection > 0
        vertical_inst_det_red_flag := true
        vertical_inst_det_pine_flag := false
        last_inst_det_red_flag := true
        last_inst_det_pine_flag := false
    else if orderDirection < 0
        vertical_inst_det_pine_flag := true
        vertical_inst_det_red_flag := false
        last_inst_det_pine_flag := true
        last_inst_det_red_flag := false

if detected and orderDirection > 0 and ema20 < ema200
    consecutive_instdet_buy_count_long6 := consecutive_instdet_buy_count_long6 + 1
else
    consecutive_instdet_buy_count_long6 := 0

if detected and orderDirection < 0 and ema20 > ema200
    consecutive_instdet_sell_count_short6 := consecutive_instdet_sell_count_short6 + 1
else
    consecutive_instdet_sell_count_short6 := 0

bgcolor(inst_bg_color, title="Institutional Detection Background")

if ema20 > ema50
    ema20_50_crossover_flag := true
    ema20_50_crossunder_flag := false

if ema20 < ema50
    ema20_50_crossunder_flag := true
    ema20_50_crossover_flag := false

if ema50 > ema200
    ema50_200_crossover_flag := true
    ema50_200_crossunder_flag := false

if ema50 < ema200
    ema50_200_crossunder_flag := true
    ema50_200_crossover_flag := false

bool ema_perfect_bearish = ema50 < ema100 and ema100 < ema200 and ema200 < ema400 and ema400 < ema800
bool ema_perfect_bullish = ema50 > ema100 and ema100 > ema200 and ema200 > ema400 and ema400 > ema800

bool ema_perfect_uptrend = ema20 > ema50 and ema50 > ema100
bool ema_perfect_downtrend = ema20 < ema50 and ema50 < ema100

int current_tf_minutes_bb = timeframe.in_seconds() / 60
bool is_60m_or_higher = current_tf_minutes_bb >= 60

bb60m_upper_slope_calc() =>
    bb_basis = ta.wma(bb60m_source, bb60m_length)
    bb_dev = ta.stdev(bb60m_source, bb60m_length)
    bb_upper = bb_basis + bb_dev * bb60m_stddev
    bb_upper_slope = (bb_upper - bb_upper[3]) / 3
    bb_upper_slope

bb60m_lower_slope_calc() =>
    bb_basis = ta.wma(bb60m_source, bb60m_length)
    bb_dev = ta.stdev(bb60m_source, bb60m_length)
    bb_lower = bb_basis - bb_dev * bb60m_stddev
    bb_lower_slope = (bb_lower - bb_lower[3]) / 3
    bb_lower_slope

var float bb60m_basis = na
var float bb60m_dev = na
var float bb60m_upper = na
var float bb60m_lower = na
var float bb60m_upper_slope = na
var float bb60m_lower_slope = na

if not is_4hr_or_higher and not is_1day_or_higher
    bb60m_basis := request.security(syminfo.tickerid, "60", ta.wma(bb60m_source, bb60m_length), barmerge.gaps_off, barmerge.lookahead_off)
    bb60m_dev := request.security(syminfo.tickerid, "60", ta.stdev(bb60m_source, bb60m_length), barmerge.gaps_off, barmerge.lookahead_off)
    bb60m_upper := bb60m_basis + bb60m_dev * bb60m_stddev
    bb60m_lower := bb60m_basis - bb60m_dev * bb60m_stddev
    
    bb60m_upper_slope := request.security(syminfo.tickerid, "60", bb60m_upper_slope_calc(), barmerge.gaps_off, barmerge.lookahead_off)
    bb60m_lower_slope := request.security(syminfo.tickerid, "60", bb60m_lower_slope_calc(), barmerge.gaps_off, barmerge.lookahead_off)
    
    bool bb_upper_crossunder = (high >= bb60m_upper or high[1] >= bb60m_upper) and close < bb60m_upper
    bool bb_lower_crossover = (low <= bb60m_lower or low[1] <= bb60m_lower) and close > bb60m_lower
    
    if bb_upper_crossunder
        bb_upper_crossed_down := true
        first_ema200_long_after_bb_displayed := false
        first_buy_after_bb_displayed := false
    
    if bb_lower_crossover
        bb_lower_crossed_up := true
        first_ema200_short_after_bb_displayed := false
        first_sell_after_bb_displayed := false
    
    if high >= bb60m_upper or low <= bb60m_upper
        bb_upper_crossed_down := false
        first_ema200_long_after_bb_displayed := false
        first_buy_after_bb_displayed := false
    
    if low <= bb60m_lower or high >= bb60m_lower
        bb_lower_crossed_up := false
        first_ema200_short_after_bb_displayed := false
        first_sell_after_bb_displayed := false

bool mtf60_npr_upper_crossunder_detected = (high[1] > npr_60m_upper[1]) and (low <= npr_60m_upper)

bool mtf60_npr_lower_crossover_detected = (low[1] < npr_60m_lower[1]) and (high >= npr_60m_lower)

bool mtf60_bb_upper_crossunder_detected = not na(bb60m_upper) and not na(bb60m_upper[1]) and (high[1] > bb60m_upper[1]) and (low <= bb60m_upper)

bool mtf60_bb_lower_crossover_detected = not na(bb60m_lower) and not na(bb60m_lower[1]) and (low[1] < bb60m_lower[1]) and (high >= bb60m_lower)

if mtf60_npr_upper_crossunder_detected
    mtf60_npr_upper_crown_crossunder_flag := true
else if mtf60_npr_lower_crossover_detected
    mtf60_npr_lower_crown_crossover_flag := true

if mtf60_bb_upper_crossunder_detected
    mtf60_bb_upper_crown_crossunder_flag := true
else if mtf60_bb_lower_crossover_detected
    mtf60_bb_lower_crown_crossover_flag := true


rbb_basis = not is_4hr_or_higher ? ta.sma(rbb_source, rbb_length) : close
rbb_dev = not is_4hr_or_higher ? rbb_mult * ta.stdev(rbb_source, rbb_length) : 0.0
rbb_upper = rbb_basis + rbb_dev
rbb_lower = rbb_basis - rbb_dev

rbb_upTrend = close > rbb_basis
rbb_downTrend = close < rbb_basis

color rbb_trendColor = rbb_upTrend ? color.new(color.red, 70) : color.new(color.lime, 70)

if rbb_upTrend
    reverse_bb_red_flag := true
    reverse_bb_lime_flag := false

if rbb_downTrend
    reverse_bb_lime_flag := true
    reverse_bb_red_flag := false

if rbb_upTrend and not rbb_upTrend[1]
    rbb_red_flag := true
    rbb_pine_flag := false

if rbb_downTrend and not rbb_downTrend[1]
    rbb_pine_flag := true
    rbb_red_flag := false

var bool down_upper_rbb_bounce_flag = false
var bool up_lower_rbb_bounce_flag = false

bool upper_rbb_bounce = not is_4hr_or_higher and (high >= rbb_upper or high[1] >= rbb_upper) and close < rbb_upper

bool lower_rbb_bounce = not is_4hr_or_higher and (low <= rbb_lower or low[1] <= rbb_lower) and close > rbb_lower

bool rbb_changed_to_red = rbb_upTrend and not rbb_upTrend[1]
bool rbb_changed_to_lime = rbb_downTrend and not rbb_downTrend[1]

if upper_rbb_bounce
    down_upper_rbb_bounce_flag := true

if lower_rbb_bounce
    up_lower_rbb_bounce_flag := true

bool vwma_bb_short_filter = not vwma_bb_enabled or (close > vwma_bb_lower1)
if show_rbb_long_short_labels and not showOnlyVWAPLongShort and down_upper_rbb_bounce_flag and rbb_changed_to_lime and vwma_bb_short_filter and vwap_short_flag
    label.new(bar_index, high, "RBB\nSHORT", 
              color=color.new(color.blue, 0), 
              textcolor=color.white, 
              style=label.style_label_down, 
              size=size.tiny, 
              yloc=yloc.abovebar)
    down_upper_rbb_bounce_flag := false
    rbb_short_displayed := true

bool vwma_bb_long_filter = not vwma_bb_enabled or (close < vwma_bb_upper1)
if show_rbb_long_short_labels and not showOnlyVWAPLongShort and up_lower_rbb_bounce_flag and rbb_changed_to_red and vwma_bb_long_filter and vwap_long_flag
    label.new(bar_index, low, "RBB\nLONG", 
              color=color.new(color.red, 0), 
              textcolor=color.white, 
              style=label.style_label_up, 
              size=size.tiny, 
              yloc=yloc.belowbar)
    up_lower_rbb_bounce_flag := false
    rbb_long_displayed := true

if enableRBBColorFilter
    if rbb_upTrend
        allow_sell_label_current := false
        allow_ema200_short_label_current := false
    
    if rbb_downTrend
        allow_buy_label_current := false
        allow_ema200_long_label_current := false

if rbb_upTrend and first_buy_long_after_rbb_red_displayed
    allow_buy_label_current := false
    allow_ema200_long_label_current := false

if rbb_downTrend and first_sell_short_after_rbb_pine_displayed
    allow_sell_label_current := false
    allow_ema200_short_label_current := false

bool price_touches_ema200 = high >= ema200 and low <= ema200
if enableAlternatingAllLabels
    if price_touches_ema200
        last_label_direction := 0
    if last_label_direction == 1
        allow_buy_label_current := false
        allow_ema200_long_label_current := false
    else if last_label_direction == -1
        allow_sell_label_current := false
        allow_ema200_short_label_current := false

if rbb_upTrend and not rbb_upTrend[1]
    rbb_changed_to_red_flag_pattern6 := true
    rbb_changed_to_red_flag_pattern7 := true
    rbb_changed_to_lime_flag_pattern6 := false
    rbb_changed_to_lime_flag_pattern7 := false
    ema200_rbb_red_flag := true
    ema200_rbb_pine_flag := false

if rbb_downTrend and not rbb_downTrend[1]
    rbb_changed_to_lime_flag_pattern6 := true
    rbb_changed_to_lime_flag_pattern7 := true
    rbb_changed_to_red_flag_pattern6 := false
    rbb_changed_to_red_flag_pattern7 := false
    ema200_rbb_pine_flag := true
    ema200_rbb_red_flag := false

float div_1m = request.security(syminfo.tickerid, "1", ((ta.ema(close, 20) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 50) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 100) - ta.ema(close, 200)) / ta.ema(close, 200) * 100) / 3, barmerge.gaps_off, barmerge.lookahead_off)
float div_5m = request.security(syminfo.tickerid, "5", ((ta.ema(close, 20) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 50) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 100) - ta.ema(close, 200)) / ta.ema(close, 200) * 100) / 3, barmerge.gaps_off, barmerge.lookahead_off)
float div_15m = request.security(syminfo.tickerid, "15", ((ta.ema(close, 20) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 50) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 100) - ta.ema(close, 200)) / ta.ema(close, 200) * 100) / 3, barmerge.gaps_off, barmerge.lookahead_off)
float div_1h = request.security(syminfo.tickerid, "60", ((ta.ema(close, 20) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 50) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 100) - ta.ema(close, 200)) / ta.ema(close, 200) * 100) / 3, barmerge.gaps_off, barmerge.lookahead_off)
float div_4h = request.security(syminfo.tickerid, "240", ((ta.ema(close, 20) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 50) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 100) - ta.ema(close, 200)) / ta.ema(close, 200) * 100) / 3, barmerge.gaps_off, barmerge.lookahead_off)
float div_1d = request.security(syminfo.tickerid, "D", ((ta.ema(close, 20) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 50) - ta.ema(close, 200)) / ta.ema(close, 200) * 100 + (ta.ema(close, 100) - ta.ema(close, 200)) / ta.ema(close, 200) * 100) / 3, barmerge.gaps_off, barmerge.lookahead_off)

