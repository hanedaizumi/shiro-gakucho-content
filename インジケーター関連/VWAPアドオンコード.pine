enableNPRException2 = input.bool(true, "⭐ Exception ②: First BUY/SELL after NPR cross", group=grpEMAExceptions, tooltip="⭐ DEFAULT ON | After 60m NPR crossdown, show FIRST BUY label (own + MTF). After 60m NPR crossup, show FIRST SELL label (own + MTF).")
enableBBException3 = input.bool(true, "⭐ Exception ③: First EMA200 after BB cross", group=grpEMAExceptions, tooltip="⭐ DEFAULT ON | After 60m BB crossdown, show FIRST EMA200 LONG. After 60m BB crossup, show FIRST EMA200 SHORT.")
enableBBException4 = input.bool(true, "⭐ Exception ④: First BUY/SELL after BB cross", group=grpEMAExceptions, tooltip="⭐ DEFAULT ON | After 60m BB crossdown, show FIRST BUY label (own + MTF). After 60m BB crossup, show FIRST SELL label (own + MTF).")


