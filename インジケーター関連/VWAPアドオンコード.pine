    table.cell(divergence_mtf_table, 3, 2, ema_4h_text, bgcolor=color.new(ema_4h_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    
    string rbb_1h_text = rbb_1h_uptrend ? "UP" : "DOWN"
