        div_lower_rbb_crossover_flag := true

float aggressive_label_atr_offset = ta.atr(14) * 1.5

bool is_perfect_uptrend = ema20 > ema50 and ema50 > ema100 and ema100 > ema200
bool is_perfect_downtrend = ema20 < ema50 and ema50 < ema100 and ema100 < ema200

bool is_bullish_candle = close > open
bool is_bearish_candle = close < open

