[st_1m, stTrend_1m, rbb_1m_uptrend, ema20_1m, ema50_1m] = request.security(syminfo.tickerid, "1", [supertrend, stTrend, close > rbb_basis, ema20, ema50])

divergence_mtf_table_pos = switch divergence_mtf_table_position
    "Top Left"     => position.top_left
    "Top Right"    => position.top_right
    "Middle Left"  => position.middle_left
    "Middle Right" => position.middle_right
    "Bottom Left"  => position.bottom_left
    "Bottom Right" => position.bottom_right
    => position.bottom_left

var table divergence_mtf_table = na
if display_divergence_mtf_table
    if na(divergence_mtf_table)
        divergence_mtf_table := table.new(divergence_mtf_table_pos, 4, 7, border_width=1, border_color=color.new(color.gray, 32))
    
    table.cell(divergence_mtf_table, 0, 0, "TF", bgcolor=color.new(color.gray, 32), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 1, 0, "RBB", bgcolor=color.new(color.gray, 32), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 2, 0, "ST", bgcolor=color.new(color.gray, 32), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 3, 0, "EMA", bgcolor=color.new(color.gray, 32), text_color=color.white, text_size=size.tiny)
    
    string rbb_1d_text = rbb_1d_uptrend ? "UP" : "DOWN"
    color rbb_1d_bgcolor = rbb_1d_uptrend ? color.red : color.blue
    string st_1d_text = stTrend_1d == 1 ? "BUY" : stTrend_1d == -1 ? "SELL" : "-"
    color st_1d_bgcolor = stTrend_1d == 1 ? color.red : stTrend_1d == -1 ? color.blue : color.gray
    string ema_1d_text = ema20_1d > ema50_1d ? "UP" : "DOWN"
    color ema_1d_bgcolor = ema20_1d > ema50_1d ? color.red : color.blue
    table.cell(divergence_mtf_table, 0, 1, "1d", bgcolor=color.new(color.gray, 32), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 1, 1, rbb_1d_text, bgcolor=color.new(rbb_1d_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 2, 1, st_1d_text, bgcolor=color.new(st_1d_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 3, 1, ema_1d_text, bgcolor=color.new(ema_1d_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    
    string rbb_4h_text = rbb_4h_uptrend ? "UP" : "DOWN"
