var float ha_close = na
var float ha_open = na
float ha_high = na
float ha_low = na

ha_close := (open + high + low + close) / 4

ha_open := na(ha_open[1]) ? (open + close) / 2 : (ha_open[1] + ha_close[1]) / 2

ha_high := math.max(high, math.max(ha_open, ha_close))
ha_low := math.min(low, math.min(ha_open, ha_close))

bool ha_bullish = ha_close > ha_open
bool ha_bearish = ha_close < ha_open

var bool ha_was_bullish = false
var bool ha_was_bearish = false

bool ha_turned_bullish = ha_bullish and ha_was_bearish
bool ha_turned_bearish = ha_bearish and ha_was_bullish

ha_was_bullish := ha_bullish
ha_was_bearish := ha_bearish

