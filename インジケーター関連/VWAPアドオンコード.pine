int curr_div_15m_state = div_15m > 0 ? 1 : (div_15m < 0 ? -1 : 0)
int curr_div_1h_state = div_1h > 0 ? 1 : (div_1h < 0 ? -1 : 0)
int curr_div_4h_state = div_4h > 0 ? 1 : (div_4h < 0 ? -1 : 0)
int curr_div_1d_state = div_1d > 0 ? 1 : (div_1d < 0 ? -1 : 0)

int mtf_up_count = 0
int mtf_down_count = 0

if div_1m > 0
    mtf_up_count += 1
else if div_1m < 0
    mtf_down_count += 1

if div_5m > 0
    mtf_up_count += 1
else if div_5m < 0
    mtf_down_count += 1

if div_15m > 0
    mtf_up_count += 1
