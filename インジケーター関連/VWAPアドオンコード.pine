    table.cell(divergence_mtf_table, 2, 3, st_1h_text, bgcolor=color.new(st_1h_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 3, 3, ema_1h_text, bgcolor=color.new(ema_1h_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    
    string rbb_15m_text = rbb_15m_uptrend ? "UP" : "DOWN"
    color rbb_15m_bgcolor = rbb_15m_uptrend ? color.red : color.blue
    string st_15m_text = stTrend_15m == 1 ? "BUY" : stTrend_15m == -1 ? "SELL" : "-"
    color st_15m_bgcolor = stTrend_15m == 1 ? color.red : stTrend_15m == -1 ? color.blue : color.gray
    string ema_15m_text = ema20_15m > ema50_15m ? "UP" : "DOWN"
    color ema_15m_bgcolor = ema20_15m > ema50_15m ? color.red : color.blue
    table.cell(divergence_mtf_table, 0, 4, "15m", bgcolor=color.new(color.gray, 32), text_color=color.white, text_size=size.tiny)
