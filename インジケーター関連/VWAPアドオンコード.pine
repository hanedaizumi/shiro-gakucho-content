    table.cell(divergence_mtf_table, 3, 4, ema_15m_text, bgcolor=color.new(ema_15m_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    
    string rbb_5m_text = rbb_5m_uptrend ? "UP" : "DOWN"
    color rbb_5m_bgcolor = rbb_5m_uptrend ? color.red : color.blue
    string st_5m_text = stTrend_5m == 1 ? "BUY" : stTrend_5m == -1 ? "SELL" : "-"
    color st_5m_bgcolor = stTrend_5m == 1 ? color.red : stTrend_5m == -1 ? color.blue : color.gray
    string ema_5m_text = ema20_5m > ema50_5m ? "UP" : "DOWN"
    color ema_5m_bgcolor = ema20_5m > ema50_5m ? color.red : color.blue
    table.cell(divergence_mtf_table, 0, 5, "5m", bgcolor=color.new(color.gray, 32), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 1, 5, rbb_5m_text, bgcolor=color.new(rbb_5m_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 2, 5, st_5m_text, bgcolor=color.new(st_5m_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 3, 5, ema_5m_text, bgcolor=color.new(ema_5m_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    
    string rbb_1m_text = rbb_1m_uptrend ? "UP" : "DOWN"
    color rbb_1m_bgcolor = rbb_1m_uptrend ? color.red : color.blue
    string st_1m_text = stTrend_1m == 1 ? "BUY" : stTrend_1m == -1 ? "SELL" : "-"
    color st_1m_bgcolor = stTrend_1m == 1 ? color.red : stTrend_1m == -1 ? color.blue : color.gray
    string ema_1m_text = ema20_1m > ema50_1m ? "UP" : "DOWN"
    color ema_1m_bgcolor = ema20_1m > ema50_1m ? color.red : color.blue
    table.cell(divergence_mtf_table, 0, 6, "1m", bgcolor=color.new(color.gray, 32), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 1, 6, rbb_1m_text, bgcolor=color.new(rbb_1m_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 2, 6, st_1m_text, bgcolor=color.new(st_1m_bgcolor, 30), text_color=color.white, text_size=size.tiny)
    table.cell(divergence_mtf_table, 3, 6, ema_1m_text, bgcolor=color.new(ema_1m_bgcolor, 30), text_color=color.white, text_size=size.tiny)




bool allow_buy_angle = not enableEMA200AngleFilter or ema200_angle_increasing
if tier1_buy and bullish_choch_detected and not ema20_block_long and uf_allow_buy and allow_buy_angle and ema_order_allow_long
    int _unused = 0

else if (not tier1_buy and not tier1_sell) and rbb_upTrend and bullish_choch_detected and not ema20_block_long and uf_allow_buy and allow_buy_angle and ema_order_allow_long
    int _unused = 0

if buy_flag and long_flag and ema50 < ema200
    sell_flag := false
    short_flag := false

bool allow_sell_angle = not enableEMA200AngleFilter or ema200_angle_decreasing
if tier1_sell and bearish_choch_detected and not ema20_block_short and uf_allow_sell and allow_sell_angle and ema_order_allow_short
    int _unused = 0

else if (not tier1_buy and not tier1_sell) and not rbb_upTrend and bearish_choch_detected and not ema20_block_short and uf_allow_sell and allow_sell_angle and ema_order_allow_short
    int _unused = 0

if sell_flag and short_flag and ema50 > ema200
    buy_flag := false
    long_flag := false


if ema200 > ema200[1]
    ema200_trend_up_flag := true
    ema200_trend_down_flag := false
else if ema200 < ema200[1]
    ema200_trend_down_flag := true
    ema200_trend_up_flag := false

if ema20 > ema50
    ema20_ema50_trend_up_flag := true
    ema20_ema50_trend_down_flag := false
else if ema20 < ema50
    ema20_ema50_trend_down_flag := true
    ema20_ema50_trend_up_flag := false

if ema50 > ema200
    ema50_ema200_trend_up_flag := true
    ema50_ema200_trend_down_flag := false
else if ema50 < ema200
    ema50_ema200_trend_down_flag := true
    ema50_ema200_trend_up_flag := false

if ta.crossover(close, ema200)
    ema200_crossover_bar := bar_index
    
if ta.crossunder(close, ema200)
    ema200_crossunder_bar := bar_index

if bar_index - ema200_crossover_bar >= 3 and low > ema200 and low[1] > ema200[1] and low[2] > ema200[2]
    ema200_crossover_completed_flag := true
    ema200_crossover_completed_bar := bar_index
    
if bar_index - ema200_crossunder_bar >= 3 and high < ema200 and high[1] < ema200[1] and high[2] < ema200[2]
    ema200_crossunder_completed_flag := true
    ema200_crossunder_completed_bar := bar_index

if ta.crossover(close, ema200) and (bar_index - ema200_crossunder_bar <= 2)
    ema200_rebound_up_flag := true
    ema200_rebound_up_count += 1
    ema200_rebound_up_bar := bar_index
    
if ta.crossunder(close, ema200) and (bar_index - ema200_crossover_bar <= 2)
    ema200_rebound_down_flag := true
    ema200_rebound_down_count += 1
    ema200_rebound_down_bar := bar_index

if low < ema200 and close > ema200 and close[1] > ema200
    ema200_rebound_up_flag := true
    ema200_rebound_up_count += 1
    ema200_rebound_up_bar := bar_index

if high > ema200 and close < ema200 and close[1] < ema200
    ema200_rebound_down_flag := true
    ema200_rebound_down_count += 1
    ema200_rebound_down_bar := bar_index


if showEMA200LongShort and showLongShortLabels and useEMA200Long7 and ema7_long_detection and rbb_red_flag and ema200_rbb_red_flag and (not alternateEMA200_7 or last_ema200_7_direction != 1) and ema20 > ema50 and ema20 > ema20[5] and ema50 > ema50[5]
    bool add_crown_open = not na(last_buy_long_open) and open > last_buy_long_open
    bool add_crown_cross = ema200_crown_crossover_flag or mtf60_ema200_crown_crossover_flag or mtf60_npr_lower_crown_crossover_flag or mtf60_bb_lower_crown_crossover_flag
    bool add_crown_angle = allow_buy_angle
    bool add_crown = add_crown_open or add_crown_cross or add_crown_angle
    
    if not showOnlyVWAPLongShort
        string label_text = "EMA200\nLONG #7\n" + str.tostring(ema_convergence_index, "#.###") + "%"
        label.new(bar_index, low - label_atr_offset * 1.5, 
                  text=label_text, 
                  style=label.style_label_up, 
                  size=size.tiny, 
                  color=color.new(color.red, 80), 
                  textcolor=color.white)
    last_buy_long_open := open
    
    ema200_7_long_displayed := true
    ema200_long_label_displayed := true
    last_ema200_7_direction := 1
    
    if add_crown
        crowned_buy_long_displayed := true
    
    if ema100_7_crossover_flag and not ema200_7_crossover_flag
        ema100_7_crossover_done_flag := true
    if ema50_7_crossover_flag and not ema200_7_crossover_flag
        ema50_7_crossover_done_flag := true
    
    ema200_7_crossover_flag := false
    ema100_7_crossover_flag := false
    ema50_7_crossover_flag := false
    ema200_rbb_red_flag := false
    if not na(vwapValue) and ema20 > ema50 and ema20 > ema20[5] and ema50 > ema50[5]
        label.new(bar_index, low - label_atr_offset * 2.0, text="VWAP\nLONG", style=label.style_label_up, size=size.tiny, color=color.new(color.red, 20), textcolor=color.white)
        vwap_long2_displayed := true

if showEMA200LongShort and showLongShortLabels and useEMA200Short7 and ema7_short_detection and rbb_pine_flag and ema200_rbb_pine_flag and (not alternateEMA200_7 or last_ema200_7_direction != -1) and ema20 < ema50 and ema20 < ema20[5] and ema50 < ema50[5]
    bool add_crown_open = not na(last_sell_short_open) and open < last_sell_short_open
    bool add_crown_cross = ema200_crown_crossunder_flag or mtf60_ema200_crown_crossunder_flag or mtf60_npr_upper_crown_crossunder_flag or mtf60_bb_upper_crown_crossunder_flag
    bool add_crown_angle = allow_sell_angle
    bool add_crown = add_crown_open or add_crown_cross or add_crown_angle
    
    if not showOnlyVWAPLongShort
        string label_text = "EMA200\nSHORT #7\n" + str.tostring(ema_convergence_index, "#.###") + "%"
        label.new(bar_index, high + label_atr_offset * 1.5, 
                  text=label_text, 
                  style=label.style_label_down, 
                  size=size.tiny, 
                  color=color.new(color.blue, 80), 
                  textcolor=color.white)
    last_sell_short_open := open
    
    ema200_7_short_displayed := true
    ema200_short_label_displayed := true
    last_ema200_7_direction := -1
    
    if add_crown
        crowned_sell_short_displayed := true
    
    if ema100_7_crossunder_flag and not ema200_7_crossunder_flag
        ema100_7_crossunder_done_flag := true
    if ema50_7_crossunder_flag and not ema200_7_crossunder_flag
        ema50_7_crossunder_done_flag := true
    
    ema200_7_crossunder_flag := false
    ema100_7_crossunder_flag := false
    ema50_7_crossunder_flag := false
    ema200_rbb_pine_flag := false
    if not na(vwapValue) and ema20 < ema50 and ema20 < ema20[5] and ema50 < ema50[5]
        label.new(bar_index, high + label_atr_offset * 2.0, text="VWAP\nSHORT", style=label.style_label_down, size=size.tiny, color=color.new(color.blue, 20), textcolor=color.white)
        vwap_short2_displayed := true

if false and showLongShortLabels and useVWAPLong and not showOnlyEMA200_7 and vwap_crossover_flag and vwap_slope_positive and rbb_red_flag and allow_buy_angle and uf_allow_buy and ema_order_allow_long
    label.new(bar_index, low - label_atr_offset * 1.5, 
              text="VWAP\nLONG", 
              style=label.style_label_up, 
              size=size.small, 
              color=color.new(color.red, 0), 
              textcolor=color.white)
    vwap_long_displayed := true
    ema200_long_label_displayed := true
    vwap_crossover_flag := false
    vwap_long_flag := true
    vwap_short_flag := false

if false and showLongShortLabels and useVWAPShort and not showOnlyEMA200_7 and vwap_crossunder_flag and vwap_slope_negative and rbb_pine_flag and allow_sell_angle and uf_allow_sell and ema_order_allow_short
    label.new(bar_index, high + label_atr_offset * 1.5, 
              text="VWAP\nSHORT", 
              style=label.style_label_down, 
              size=size.small, 
              color=color.new(color.blue, 0), 
              textcolor=color.white)
    vwap_short_displayed := true
    ema200_short_label_displayed := true
    vwap_crossunder_flag := false
