bool ema7_short_detection = ema200_7_crossunder_flag or (ema100_7_crossunder_flag and not ema100_7_crossunder_done_flag) or (ema50_7_crossunder_flag and not ema50_7_crossunder_done_flag) or vwap_crossunder_touch



