bool ema50_crossover_touch_long5 = ta.crossover(close, ema50) or (low <= ema50 and close > ema50 and not (low[1] <= ema50[1] and close[1] > ema50[1]))
if ema50_crossover_touch_long5
    close_ema50_crossover_count_ema50_long5 := close_ema50_crossover_count_ema50_long5 + 1
    if close_ema50_crossover_count_ema50_long5 == 1
        close_ema50_crossover_flag1_ema50_long5 := true
    else if close_ema50_crossover_count_ema50_long5 >= 2
        close_ema50_crossover_flag2_ema50_long5 := true

if ta.crossunder(ema7, ema20)
    ema7_20_crossunder_flag_ema50_short5 := true
    ema7_20_crossunder_flag_60m_ema50_short5 := true

if ta.crossunder(ema7, ema50)
    ema7_50_crossunder_flag_ema50_short5 := true
    ema7_50_crossunder_flag_60m_ema50_short5 := true

bool ema50_crossunder_touch_short5 = ta.crossunder(close, ema50) or (high >= ema50 and close < ema50 and not (high[1] >= ema50[1] and close[1] < ema50[1]))
if ema50_crossunder_touch_short5
    close_ema50_crossunder_count_ema50_short5 := close_ema50_crossunder_count_ema50_short5 + 1
    if close_ema50_crossunder_count_ema50_short5 == 1
        close_ema50_crossunder_flag1_ema50_short5 := true
    else if close_ema50_crossunder_count_ema50_short5 >= 2
        close_ema50_crossunder_flag2_ema50_short5 := true

if enableMTFEMA200BBFilter and not na(ema200_60m) and not na(bb60m_upper) and not na(bb60m_lower)
    bool touching_ema200_60m = (high >= ema200_60m and low <= ema200_60m)
    if touching_ema200_60m
        allow_buy_label_current := false
        allow_sell_label_current := false
        allow_ema200_long_label_current := false
        allow_ema200_short_label_current := false
    
    if close < ema200_60m and not touching_ema200_60m
        if bb60m_lower_slope < 0
            allow_buy_label_current := false
            allow_ema200_long_label_current := false
        else if bb60m_lower_slope > 0
            allow_sell_label_current := false
            allow_ema200_short_label_current := false
    
    if close > ema200_60m and not touching_ema200_60m
        if bb60m_upper_slope < 0
            allow_buy_label_current := false
            allow_ema200_long_label_current := false
        else if bb60m_upper_slope > 0
            allow_sell_label_current := false
            allow_ema200_short_label_current := false

float ema20_60m = not is_4hr_or_higher ? request.security(syminfo.tickerid, "60", ta.ema(close, 20), barmerge.gaps_off, barmerge.lookahead_off) : na
float ema50_60m = not is_4hr_or_higher ? request.security(syminfo.tickerid, "60", ta.ema(close, 50), barmerge.gaps_off, barmerge.lookahead_off) : na

if not na(ema200_60m) and not na(ema200_60m[1])
    float slope_60m = ema200_60m - ema200_60m[1]
    ema200_60m_trend_up_flag := slope_60m > 0
    ema200_60m_trend_down_flag := slope_60m < 0

if ta.crossover(close, ema200_60m)
    ema200_60m_BUY_activated_flag := true
    ema200_60m_SELL_activated_flag := false

if ta.crossunder(close, ema200_60m)
    ema200_60m_SELL_activated_flag := true
    ema200_60m_BUY_activated_flag := false

bool ema200_60m_crossover_touch = ta.crossover(close, ema200_60m) or (low <= ema200_60m and close > ema200_60m)
bool ema200_60m_crossunder_touch = ta.crossunder(close, ema200_60m) or (high >= ema200_60m and close < ema200_60m)

if ema200_60m_crossover_touch
    ema200_60m_crossover_bar := bar_index
    ema200_60m_crossover_completed_flag := false

if ema200_60m_crossunder_touch
    ema200_60m_crossunder_bar := bar_index
    ema200_60m_crossunder_completed_flag := false

if bar_index - ema200_60m_crossover_bar >= 3 and low > ema200_60m and low[1] > ema200_60m[1] and low[2] > ema200_60m[2]
    ema200_60m_crossover_completed_flag := true
    ema200_60m_crossover_completed_bar := bar_index

if bar_index - ema200_60m_crossunder_bar >= 3 and high < ema200_60m and high[1] < ema200_60m[1] and high[2] < ema200_60m[2]
    ema200_60m_crossunder_completed_flag := true
    ema200_60m_crossunder_completed_bar := bar_index

if ta.crossover(close, ema200_60m) and (bar_index - ema200_60m_crossunder_bar <= 2)
    ema200_60m_rebound_up_flag := true
    ema200_60m_rebound_up_count += 1
    ema200_60m_rebound_up_bar := bar_index

if ta.crossunder(close, ema200_60m) and (bar_index - ema200_60m_crossover_bar <= 2)
    ema200_60m_rebound_down_flag := true
    ema200_60m_rebound_down_count += 1
    ema200_60m_rebound_down_bar := bar_index

if low < ema200_60m and close > ema200_60m and close[1] > ema200_60m[1]
    ema200_60m_rebound_up_flag := true
    ema200_60m_rebound_up_count += 1
    ema200_60m_rebound_up_bar := bar_index

if high > ema200_60m and close < ema200_60m and close[1] < ema200_60m[1]
    ema200_60m_rebound_down_flag := true
    ema200_60m_rebound_down_count += 1
    ema200_60m_rebound_down_bar := bar_index

if not na(ema20_60m) and not na(ema50_60m)
    if ta.crossover(ema20_60m, ema50_60m)
        ema200_60m_ema20_ema50_trend_up_flag := true
        ema200_60m_ema20_ema50_trend_down_flag := false
    
    if ta.crossunder(ema20_60m, ema50_60m)
        ema200_60m_ema20_ema50_trend_down_flag := true
        ema200_60m_ema20_ema50_trend_up_flag := false

bool ema50_60m_crossover_touch_long5 = ta.crossover(close, ema50_60m) or (low <= ema50_60m and close > ema50_60m and not (low[1] <= ema50_60m[1] and close[1] > ema50_60m[1]))
if ema50_60m_crossover_touch_long5
    close_ema50_60m_crossover_count_60m_ema50_long5 := close_ema50_60m_crossover_count_60m_ema50_long5 + 1
    if close_ema50_60m_crossover_count_60m_ema50_long5 == 1
        close_ema50_60m_crossover_flag1_60m_ema50_long5 := true
    else if close_ema50_60m_crossover_count_60m_ema50_long5 >= 2
        close_ema50_60m_crossover_flag2_60m_ema50_long5 := true

bool ema50_60m_crossunder_touch_short5 = ta.crossunder(close, ema50_60m) or (high >= ema50_60m and close < ema50_60m and not (high[1] >= ema50_60m[1] and close[1] < ema50_60m[1]))
if ema50_60m_crossunder_touch_short5
    close_ema50_60m_crossunder_count_60m_ema50_short5 := close_ema50_60m_crossunder_count_60m_ema50_short5 + 1
    if close_ema50_60m_crossunder_count_60m_ema50_short5 == 1
        close_ema50_60m_crossunder_flag1_60m_ema50_short5 := true
    else if close_ema50_60m_crossunder_count_60m_ema50_short5 >= 2
        close_ema50_60m_crossunder_flag2_60m_ema50_short5 := true


bool touching_upper_npr_60m = not na(npr60m_upper) and high >= npr60m_upper * 0.998 and high <= npr60m_upper * 1.002
bool touching_lower_npr_60m = not na(npr60m_lower) and low <= npr60m_lower * 1.002 and low >= npr60m_lower * 0.998

bool hide_buy_div = touching_upper_npr_60m and not is_perfect_uptrend
bool hide_sell_div = touching_lower_npr_60m and not is_perfect_downtrend

if enableUltimateFilter
    bool uf_touching_upper_npr = high >= npr60m_upper * 0.998 and high <= npr60m_upper * 1.002
    if uf_touching_upper_npr
        uf_lower_npr_flag := false
        uf_upper_npr_flag := true
    
    bool uf_touching_lower_npr = low <= npr60m_lower * 1.002 and low >= npr60m_lower * 0.998
    if uf_touching_lower_npr
        uf_upper_npr_flag := false
        uf_lower_npr_flag := true
    
    bool uf_touching_upper_bb = high >= bb60m_upper * 0.998 and high <= bb60m_upper * 1.002
    if uf_touching_upper_bb
        uf_lower_bb_flag := false
        uf_upper_bb_flag := true
    
    bool uf_touching_lower_bb = low <= bb60m_lower * 1.002 and low >= bb60m_lower * 0.998
    if uf_touching_lower_bb
        uf_upper_bb_flag := false
        uf_lower_bb_flag := true
    
    bool ema200_full_crossunder = (close < ema200 and open < ema200) and (close[1] >= ema200[1] or open[1] >= ema200[1])
    if ema200_full_crossunder
        uf_ema200_crossover_flag := false
        uf_ema200_crossunder_flag := true
    
    bool ema200_full_crossover = (close > ema200 and open > ema200) and (close[1] <= ema200[1] or open[1] <= ema200[1])
    if ema200_full_crossover
        uf_ema200_crossunder_flag := false
        uf_ema200_crossover_flag := true
    
    if ta.crossover(ema7, ema20)
        uf_bear_flag := false
        uf_bull_flag := true
    
    if ta.crossunder(ema7, ema20)
        uf_bull_flag := false
        uf_bear_flag := true

bool is_5min_chart = timeframe.in_seconds("") == 300

var float ema50_15m = na
