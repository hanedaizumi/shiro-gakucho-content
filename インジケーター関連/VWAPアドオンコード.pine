bool div_15m_is_down = mtf_down_count >= 1

string star_string_buy = ""
if mtf_up_count >= 1
    for i = 0 to mtf_up_count - 1
        star_string_buy := star_string_buy + "🌟"

string star_string_sell = ""
if mtf_down_count >= 1
    for i = 0 to mtf_down_count - 1
        star_string_sell := star_string_sell + "🌟"

if not is_4hr_or_higher and not na(rbb_upper)
    if ta.crossover(close, rbb_upper) or ta.crossunder(close, rbb_upper) or (high >= rbb_upper)
        upper_RBB_touch_flag := true

if not is_4hr_or_higher and not na(rbb_lower)
    if ta.crossover(close, rbb_lower) or ta.crossunder(close, rbb_lower) or (low <= rbb_lower)
        lower_RBB_touch_flag := true

if not is_4hr_or_higher and not na(rbb_upper)
    if ta.crossunder(close, rbb_upper)
        div_upper_rbb_crossunder_flag := true

if not is_4hr_or_higher and not na(rbb_lower)
