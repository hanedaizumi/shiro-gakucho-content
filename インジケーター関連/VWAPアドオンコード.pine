    if showEMA200LongShort and useEMA200Long5 and vwap_long_flag and mtf2_ema200_long5 and not mtf2_ema200_long5[1] and allow_ema200_long_label_current and not is15minChart and rbb_red_flag and instdet_red_flag_filter and ema_convergence_filter_pass
        bool add_crown = ema200_crown_crossover_flag or mtf60_ema200_crown_crossover_flag or mtf60_npr_lower_crown_crossover_flag or mtf60_bb_lower_crown_crossover_flag
        if not enableCrownOnlyFilter or add_crown
            string label_text = "[15M] EMA200\nLONG #5"
            label.new(bar_index, low - label_atr_offset * 1.5, 
                      text=label_text, 
                      style=label.style_label_up, 
                  size=size.tiny, 
                      color=color.new(color.red, 80), 
                      textcolor=color.white)
            last_buy_long_open := open
            if add_crown
                crowned_buy_long_displayed := true
            last_label_direction := 1
            if add_crown
                ema200_crown_crossover_flag := false
                mtf60_ema200_crown_crossover_flag := false
                mtf60_npr_lower_crown_crossover_flag := false
                mtf60_bb_lower_crown_crossover_flag := false
    
    if showEMA200LongShort and useEMA200Short5 and vwap_short_flag and mtf2_ema200_short5 and not mtf2_ema200_short5[1] and allow_ema200_short_label_current and not is15minChart and rbb_pine_flag and instdet_pine_flag_filter and ema_convergence_filter_pass
        bool add_crown = ema200_crown_crossunder_flag or mtf60_ema200_crown_crossunder_flag or mtf60_npr_upper_crown_crossunder_flag or mtf60_bb_upper_crown_crossunder_flag
        if not enableCrownOnlyFilter or add_crown
            string label_text = "[15M] EMA200\nSHORT #5"
            label.new(bar_index, high + label_atr_offset * 1.5, 
                      text=label_text, 
                      style=label.style_label_down, 
                  size=size.tiny, 
                      color=color.new(color.blue, 80), 
                      textcolor=color.white)
            last_sell_short_open := open
            if add_crown
                crowned_sell_short_displayed := true
            last_label_direction := -1
            if add_crown
                ema200_crown_crossunder_flag := false
                mtf60_ema200_crown_crossunder_flag := false
                mtf60_npr_upper_crown_crossunder_flag := false
                mtf60_bb_upper_crown_crossunder_flag := false
    
    if (mtf2_buy1 and not mtf2_buy1[1] or mtf2_buy2 and not mtf2_buy2[1] or mtf2_ema200_long5 and not mtf2_ema200_long5[1]) and allow_buy_label_current and rbb_upTrend and not first_buy_long_after_rbb_red_displayed and not is15minChart
        first_buy_long_after_rbb_red_displayed := true
    
    if (mtf2_sell1 and not mtf2_sell1[1] or mtf2_sell2 and not mtf2_sell2[1] or mtf2_ema200_short5 and not mtf2_ema200_short5[1]) and allow_sell_label_current and rbb_downTrend and not first_sell_short_after_rbb_pine_displayed and not is15minChart
        first_sell_short_after_rbb_pine_displayed := true
    
    
    
    if showEMA200LongShort and useEMA200Long5 and vwap_long_flag and mtf4_ema200_long5 and not mtf4_ema200_long5[1] and ((is_mtf_1min and mytime_trend_up_flag) or (not is_mtf_1min and allow_ema200_long_label_current)) and rbb_red_flag and instdet_red_flag_filter and ema_convergence_filter_pass
        bool add_crown = ema200_crown_crossover_flag or mtf60_ema200_crown_crossover_flag or mtf60_npr_lower_crown_crossover_flag or mtf60_bb_lower_crown_crossover_flag
        if not enableCrownOnlyFilter or add_crown
            string label_text = mtf4_label + " EMA200\nLONG #5"
            label.new(bar_index, low - label_atr_offset * 1.5, 
                      text=label_text, 
                      style=label.style_label_up, 
                      size=size.tiny, 
                      color=color.new(color.teal, 80), 
                      textcolor=color.white)
            last_buy_long_open := open
            if add_crown
                crowned_buy_long_displayed := true
            last_label_direction := 1
            if add_crown
                ema200_crown_crossover_flag := false
                mtf60_ema200_crown_crossover_flag := false
                mtf60_npr_lower_crown_crossover_flag := false
                mtf60_bb_lower_crown_crossover_flag := false
    
    if showEMA200LongShort and useEMA200Short5 and vwap_short_flag and mtf4_ema200_short5 and not mtf4_ema200_short5[1] and ((is_mtf_1min and mytime_trend_down_flag) or (not is_mtf_1min and allow_ema200_short_label_current)) and rbb_pine_flag and instdet_pine_flag_filter and ema_convergence_filter_pass
        bool add_crown = ema200_crown_crossunder_flag or mtf60_ema200_crown_crossunder_flag or mtf60_npr_upper_crown_crossunder_flag or mtf60_bb_upper_crown_crossunder_flag
        if not enableCrownOnlyFilter or add_crown
            string label_text = mtf4_label + " EMA200\nSHORT #5"
            label.new(bar_index, high + label_atr_offset * 1.5, 
                      text=label_text, 
                      style=label.style_label_down, 
                      size=size.tiny, 
                      color=color.new(color.teal, 80), 
                      textcolor=color.white)
            last_sell_short_open := open
            if add_crown
                crowned_sell_short_displayed := true
            last_label_direction := -1
            if add_crown
                ema200_crown_crossunder_flag := false
                mtf60_ema200_crown_crossunder_flag := false
                mtf60_npr_upper_crown_crossunder_flag := false
                mtf60_bb_upper_crown_crossunder_flag := false
    
    if (mtf4_buy1 and not mtf4_buy1[1] or mtf4_buy2 and not mtf4_buy2[1] or mtf4_ema200_long5 and not mtf4_ema200_long5[1]) and ((is_mtf_1min and mytime_trend_up_flag) or (not is_mtf_1min and allow_buy_label_current)) and rbb_upTrend and not first_buy_long_after_rbb_red_displayed
        first_buy_long_after_rbb_red_displayed := true
    
    if (mtf4_sell1 and not mtf4_sell1[1] or mtf4_sell2 and not mtf4_sell2[1] or mtf4_ema200_short5 and not mtf4_ema200_short5[1]) and ((is_mtf_1min and mytime_trend_down_flag) or (not is_mtf_1min and allow_sell_label_current)) and rbb_downTrend and not first_sell_short_after_rbb_pine_displayed
        first_sell_short_after_rbb_pine_displayed := true
    
    mtf_any_buy := mtf2_buy1 or mtf2_buy2 or mtf2_ema200_long5 or mtf3_buy1 or mtf3_buy2 or mtf3_ema200_long5 or mtf4_buy1 or mtf4_buy2 or mtf4_ema200_long5
    mtf_any_sell := mtf2_sell1 or mtf2_sell2 or mtf2_ema200_short5 or mtf3_sell1 or mtf3_sell2 or mtf3_ema200_short5 or mtf4_sell1 or mtf4_sell2 or mtf4_ema200_short5

bool alert_must_buy_npr_reversal = (m60_lower_npr_crossunder_flag or m60_lower_npr_crossover_flag) and rbb_changed_to_red_flag_pattern6
bool alert_must_buy_counter_trend_check = ema50 < ema200 ? not na(last_buy_label_bar) : true
bool alert_must_buy_ema200_reversal = ema200_crossover_flag and lower_RBB_touch_flag and rbb_changed_to_red_flag_pattern7 and alert_must_buy_counter_trend_check

bool alert_must_sell_npr_reversal = (m60_upper_npr_crossover_flag or m60_upper_npr_crossunder_flag) and rbb_changed_to_lime_flag_pattern6
bool alert_must_sell_counter_trend_check = ema50 > ema200 ? not na(last_sell_label_bar) : true
bool alert_must_sell_ema200_reversal = ema200_crossunder_flag and upper_RBB_touch_flag and rbb_changed_to_lime_flag_pattern7 and alert_must_sell_counter_trend_check













if (m60_lower_npr_crossunder_flag or m60_lower_npr_crossover_flag) and rbb_changed_to_red_flag_pattern6
    
    rbb_changed_to_red_flag_pattern6 := false

if (m60_upper_npr_crossover_flag or m60_upper_npr_crossunder_flag) and rbb_changed_to_lime_flag_pattern6
    
    rbb_changed_to_lime_flag_pattern6 := false

if ema200_crossover_flag and lower_RBB_touch_flag and rbb_changed_to_red_flag_pattern7
    bool is_counter_trend = ema50 < ema200
    bool has_consecutive_buy = not na(last_buy_label_bar)
    bool can_display_in_counter_trend = is_counter_trend and has_consecutive_buy
    bool can_display = not is_counter_trend or can_display_in_counter_trend
    
    bool is_strong_downtrend_must_buy = ema200 > ema100 and ema100 > ema50
    bool institutional_exception_must_buy = is_strong_downtrend_must_buy and Aggressive_Positive_Flag
    
    bool must_buy_div_check = not enableDivergenceIndexFilter or institutional_exception_must_buy or ema_convergence_index > 0
    if showMustBuySellLabels and can_display and must_buy_div_check
        bool has_aggressive_flag = Aggressive_Positive_Flag
        bool has_ema_alignment = ema50 > ema20 and ema20 > ema200
        bool has_star = div_15m_is_up
        
        bool institutional_check = not showOnlyInstitutionalLabels or has_aggressive_flag
        
        bool should_display = (has_star or not showOnlyStarLabels) and not showOnlyDivergenceLabels and institutional_check
        
        if should_display
            string label_text = has_star ? star_string_buy + "\nmust BUY\nEMA200 REV\n" + str.tostring(ema_convergence_index, "#.###") + "%" : "must BUY\nEMA200 REV\n" + str.tostring(ema_convergence_index, "#.###") + "%"
            
            last_must_buy_label := label.new(bar_index, low - label_atr_offset * 1, 
                      text=label_text, 
                      style=label.style_label_up, 
                      size=size.small, 
                      color=color.new(color.red, 80), 
                      textcolor=color.white)
            
            must_buy_bar_index := bar_index
            must_buy_was_rbb_red := rbb_upTrend
            
            
            if has_star
                star_buy_label_displayed := true
                if mtf_up_count >= 3
                    star3_buy_label_displayed := true
                if mtf_up_count >= 4
                    star4_buy_label_displayed := true
        
        if Aggressive_Positive_Flag
            Aggressive_Positive_Flag := false
        
        Aggressive_Negative_Flag := false
    
    rbb_changed_to_red_flag_pattern7 := false
    lower_RBB_touch_flag := false

if ema200_crossunder_flag and upper_RBB_touch_flag and rbb_changed_to_lime_flag_pattern7
    bool is_counter_trend = ema50 > ema200
    bool has_consecutive_sell = not na(last_sell_label_bar)
    bool can_display_in_counter_trend = is_counter_trend and has_consecutive_sell
    bool can_display = not is_counter_trend or can_display_in_counter_trend
    
    bool is_strong_uptrend_must_sell = ema200 < ema100 and ema100 < ema50
    bool institutional_exception_must_sell = is_strong_uptrend_must_sell and Aggressive_Negative_Flag
    
    bool must_sell_div_check = not enableDivergenceIndexFilter or institutional_exception_must_sell or ema_convergence_index < 0
    if showMustBuySellLabels and can_display and must_sell_div_check
        bool has_aggressive_flag = Aggressive_Negative_Flag
        bool has_ema_alignment = ema50 < ema20 and ema20 < ema200
        bool has_star = div_15m_is_down
        
        bool institutional_check = not showOnlyInstitutionalLabels or has_aggressive_flag
        
        bool should_display = (has_star or not showOnlyStarLabels) and not showOnlyDivergenceLabels and institutional_check
        
        if should_display
            string label_text = has_star ? star_string_sell + "\nmust SELL\nEMA200 REV\n" + str.tostring(ema_convergence_index, "#.###") + "%" : "must SELL\nEMA200 REV\n" + str.tostring(ema_convergence_index, "#.###") + "%"
            
            last_must_sell_label := label.new(bar_index, high + label_atr_offset * 1, 
                      text=label_text, 
                      style=label.style_label_down, 
                      size=size.small, 
                      color=color.new(color.blue, 80), 
                      textcolor=color.white)
            
            must_sell_bar_index := bar_index
            must_sell_was_rbb_lime := rbb_downTrend
            
            
            if has_star
                star_sell_label_displayed := true
                if mtf_down_count >= 3
                    star3_sell_label_displayed := true
                if mtf_down_count >= 4
                    star4_sell_label_displayed := true
        
        if Aggressive_Negative_Flag
            Aggressive_Negative_Flag := false
        
        Aggressive_Positive_Flag := false
    
    rbb_changed_to_lime_flag_pattern7 := false
    upper_RBB_touch_flag := false



if not is_4hr_or_higher and not na(rbb_upper)
    if ta.crossover(close, rbb_upper) or ta.crossunder(close, rbb_upper) or (high >= rbb_upper)
        lower_RBB_touch_flag := false

if not is_4hr_or_higher and not na(rbb_lower)
    if ta.crossover(close, rbb_lower) or ta.crossunder(close, rbb_lower) or (low <= rbb_lower)
        upper_RBB_touch_flag := false

bool any_buy_or_long = ema200_7_long_displayed or rbb_long_displayed or vwap_long_displayed

bool any_sell_or_short = ema200_7_short_displayed or rbb_short_displayed or vwap_short_displayed

bool ema20_cross_over_ema50 = ta.crossover(ema20, ema50)
bool ema20_cross_under_ema50 = ta.crossunder(ema20, ema50)

if ema20_cross_over_ema50
    st_trend_up_flag := true
    st_trend_down_flag := false

if ema20_cross_under_ema50
    st_trend_down_flag := true
    st_trend_up_flag := false

if any_buy_or_long
    alert("📊 ANY BUY/LONG Signal Detected", alert.freq_once_per_bar)

if any_sell_or_short
    alert("📊 ANY SELL/SHORT Signal Detected", alert.freq_once_per_bar)




alertcondition(any_buy_or_long, 
               title="📊 ANY BUY/LONG", 
               message="📊 ANY BUY/LONG signal detected: {{interval}}m {{ticker}}")

alertcondition(any_sell_or_short, 
               title="📊 ANY SELL/SHORT", 
               message="📊 ANY SELL/SHORT signal detected: {{interval}}m {{ticker}}")

alertcondition(ema200_7_long_displayed, 
               title="🎯 EMA200 LONG #7", 
               message="🎯 EMA200 LONG #7 signal detected: {{interval}}m {{ticker}}")

alertcondition(ema200_7_short_displayed, 
               title="🎯 EMA200 SHORT #7", 
               message="🎯 EMA200 SHORT #7 signal detected: {{interval}}m {{ticker}}")

alertcondition(vwap_long2_displayed, 
               title="📊 VWAP LONG only", 
               message="📊 VWAP LONG: {{interval}}m {{ticker}}")
alertcondition(vwap_short2_displayed, 
               title="📊 VWAP SHORT only", 
               message="📊 VWAP SHORT: {{interval}}m {{ticker}}")
alertcondition(vwap_long2_displayed or vwap_short2_displayed, 
               title="📊 VWAP LONG or SHORT (BOTH)", 
               message="📊 VWAP LONG or SHORT: {{interval}}m {{ticker}}")

if stBuySignal
    st_buy_displayed := true
    st_buy_flag := true
    st_sell_flag := false

if stSellSignal
    st_sell_displayed := true
    st_sell_flag := true
    st_buy_flag := false

plotshape(false, "Supertrend Buy Signal", shape.labelup, location.belowbar, 
          color=stBuyColor, text="ST BUY", textcolor=color.white, size=size.small)
plotshape(false, "Supertrend Sell Signal", shape.labeldown, location.abovebar, 
          color=stSellColor, text="ST SELL", textcolor=color.white, size=size.small)

var label ema_state_lbl = na
if show_ema_state_label
    label.delete(ema_state_lbl[1])
    ema_state_lbl := label.new(bar_index, high * 1.008, ema_state, 
                                color = ema_labelCol, 
                                textcolor = ema_textCol, 
                                style = label.style_label_down, 
                                size = size.normal, 
                                yloc = yloc.abovebar)

alertcondition(trend_state == 1 and trend_state[1] != 1, 
               title="🔴 強気１開始", 
               message="🔴 強気１：EMA20>50>100 になりました ↑ {{interval}}m {{ticker}}")
alertcondition(trend_state == 2 and trend_state[1] != 2, 
               title="🔴 強気２開始", 
               message="🔴 強気２：EMA20>50>100 になりました ↗ {{interval}}m {{ticker}}")
alertcondition(trend_state == 3 and trend_state[1] != 3, 
               title="🟢 弱気１開始", 
               message="🟢 弱気１：EMA20<50<100 になりました ↓ {{interval}}m {{ticker}}")
alertcondition(trend_state == 4 and trend_state[1] != 4, 
               title="🟢 弱気２開始", 
               message="🟢 弱気２：EMA20<50<100 になりました ↘ {{interval}}m {{ticker}}")

alertcondition(rbb_short_displayed, 
               title="🔵 RBB SHORT", 
               message="🔵 RBB SHORT: Upper RBB反発後、LIME変化 {{interval}}m {{ticker}}")
alertcondition(rbb_long_displayed, 
               title="🔴 RBB LONG", 
               message="🔴 RBB LONG: Lower RBB反発後、RED変化 {{interval}}m {{ticker}}")

p1 = plot(vwma_bb_upper1, color=color.new(color.orange, 100), title="VWMA BB 1st Upper", display=display.none)
p2 = plot(vwma_bb_lower1, color=color.new(color.orange, 100), title="VWMA BB 1st Lower", display=display.none)
p3 = plot(vwma_bb_upper2, color=color.new(color.red, 100), title="VWMA BB 2nd Upper", display=display.none)
p4 = plot(vwma_bb_lower2, color=color.new(color.red, 100), title="VWMA BB 2nd Lower", display=display.none)

fill(p3, p1, color=(vwma_bb_display and vwma_bb_fill_display) ? color.new(color.orange, 85) : na, title="VWMA BB 2nd Stdev Upper Fill")
fill(p4, p2, color=(vwma_bb_display and vwma_bb_fill_display) ? color.new(color.orange, 85) : na, title="VWMA BB 2nd Stdev Lower Fill")
