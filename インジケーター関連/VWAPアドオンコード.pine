float topPriceForLabels = high + label_offset






bool cross_lower_npr = ta.crossover(low, npr60m_lower) or ta.crossunder(low, npr60m_lower) or (low <= npr60m_lower and low[1] > npr60m_lower[1])
bool cross_lower_bb = ta.crossover(low, bb60m_lower) or ta.crossunder(low, bb60m_lower) or (low <= bb60m_lower and low[1] > bb60m_lower[1])
