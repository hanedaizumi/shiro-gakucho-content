    string st_1h_text = stTrend_1h == 1 ? "BUY" : stTrend_1h == -1 ? "SELL" : "-"
    color st_1h_bgcolor = stTrend_1h == 1 ? color.red : stTrend_1h == -1 ? color.blue : color.gray
    string ema_1h_text = ema20_1h > ema50_1h ? "UP" : "DOWN"
    color ema_1h_bgcolor = ema20_1h > ema50_1h ? color.red : color.blue
    table.cell(divergence_mtf_table, 0, 3, "1h", bgcolor=color.new(color.gray, 32), text_color=color.white, text_size=size.tiny)
