bool cross_upper_bb = ta.crossover(high, bb60m_upper) or ta.crossunder(high, bb60m_upper) or (high >= bb60m_upper and high[1] < bb60m_upper[1])
bool cross_upper_ema50 = ta.crossover(high, ema50) or ta.crossunder(high, ema50) or (high >= ema50 and high[1] < ema50[1])

