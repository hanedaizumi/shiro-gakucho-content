    npr60m_bull_flag := true
    npr60m_bear_flag := false

if ta.crossunder(close, npr60m_upper) or ta.crossunder(close, npr60m_lower)
    npr60m_bear_flag := true
    npr60m_bull_flag := false


if ta.crossover(close, ema200) or (low < ema200 and close > ema200)
