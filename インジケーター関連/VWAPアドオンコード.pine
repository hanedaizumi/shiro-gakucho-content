    m60_upper_npr_crossover_flag := false
    m60_upper_npr_crossunder_flag := false
    m60_lower_npr_crossunder_flag := false
    m60_lower_npr_crossover_flag := false

if ta.crossunder(close, ema200) or (high > ema200 and close < ema200)
    ema200_crossunder_flag := true
    ema200_crossover_flag := false
    div_ema200_crossunder_flag := true
    div_ema200_crossunder_bar := bar_index
    div_ema200_crossover_flag := false
    div_ema200_crossover_bar := na
    m60_upper_npr_crossover_flag := false
    m60_upper_npr_crossunder_flag := false
    m60_lower_npr_crossunder_flag := false
    m60_lower_npr_crossover_flag := false

if div_ema200_crossover_flag and not na(div_ema200_crossover_bar) and (bar_index - div_ema200_crossover_bar) >= 27
    div_ema200_crossover_flag := false
    div_ema200_crossover_bar := na

if div_ema200_crossunder_flag and not na(div_ema200_crossunder_bar) and (bar_index - div_ema200_crossunder_bar) >= 27
    div_ema200_crossunder_flag := false
    div_ema200_crossunder_bar := na

if not na(npr60m_upper)
    if ta.crossover(close, npr60m_upper) or (low < npr60m_upper and close > npr60m_upper)
        m60_upper_npr_crossover_flag := true
        m60_upper_npr_crossunder_flag := false
        m60_lower_npr_crossunder_flag := false

    if ta.crossunder(close, npr60m_upper) or (high > npr60m_upper and close < npr60m_upper)
        m60_upper_npr_crossunder_flag := true
        m60_upper_npr_crossover_flag := false
        m60_lower_npr_crossover_flag := false

if not na(npr60m_lower)
    if ta.crossunder(close, npr60m_lower) or (high > npr60m_lower and close < npr60m_lower)
        m60_lower_npr_crossunder_flag := true
        m60_upper_npr_crossover_flag := false
        m60_lower_npr_crossover_flag := false

    if ta.crossover(close, npr60m_lower) or (low < npr60m_lower and close > npr60m_lower)
        m60_lower_npr_crossover_flag := true
        m60_upper_npr_crossunder_flag := false
        m60_lower_npr_crossunder_flag := false

