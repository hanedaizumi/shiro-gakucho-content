bool vwap_slope_negative = not na(vwapValue) and not na(vwapValue[1]) and vwapValue < vwapValue[1]

bool vwap_crossover_touch = not na(vwapValue) and (ta.crossover(close, vwapValue) or (low <= vwapValue and close > vwapValue))
bool vwap_crossunder_touch = not na(vwapValue) and (ta.crossunder(close, vwapValue) or (high >= vwapValue and close < vwapValue))

