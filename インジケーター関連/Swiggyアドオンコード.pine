//@version=6
indicator("Swiggy LONG/SHORT + Killzone Only", shorttitle="Swiggy+KZ", overlay=true, max_bars_back=1500, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ========== ICT Session (Killzone) - must be early ==========
var _ict_g_SETTINGS = "ICT Settings"
ict_gmt_tz = input.string('GMT+9', "Timezone", options = ['America/New_York','GMT-12','GMT-11','GMT-10','GMT-9','GMT-8','GMT-7','GMT-6','GMT-5','GMT-4','GMT-3','GMT-2','GMT-1','GMT+0','GMT+1','GMT+2','GMT+3','GMT+4','GMT+5','GMT+6','GMT+7','GMT+8','GMT+9','GMT+10','GMT+11','GMT+12','GMT+13','GMT+14'], tooltip = "Note GMT is not adjusted to reflect Daylight Saving Time changes", group = _ict_g_SETTINGS)
var _ict_g_KZ = "ICT Killzones (Session Times)"
ict_use_sydney = input.bool(true, "", inline = "SYD", group = _ict_g_KZ)
ict_sydney = input.session("0600-0900", "", inline = "SYD", group = _ict_g_KZ)
ict_use_tokyo_am = input.bool(true, "", inline = "TKYAM", group = _ict_g_KZ)
ict_tokyo_am = input.session("0900-1200", "", inline = "TKYAM", group = _ict_g_KZ)
ict_use_tokyolunch = input.bool(false, "", inline = "TKYLUNCH", group = _ict_g_KZ)
ict_tokyolunch = input.session("1130-1230", "", inline = "TKYLUNCH", group = _ict_g_KZ)
ict_use_tokyo_pm = input.bool(true, "", inline = "TKYPM", group = _ict_g_KZ)
ict_tokyo_pm = input.session("1200-1500", "", inline = "TKYPM", group = _ict_g_KZ)
ict_use_ukmorning = input.bool(true, "", inline = "UKMORN", group = _ict_g_KZ)
ict_ukmorning = input.session("1500-1700", "", inline = "UKMORN", group = _ict_g_KZ)
ict_use_ukam = input.bool(true, "", inline = "UKAM", group = _ict_g_KZ)
ict_ukam = input.session("1700-1900", "", inline = "UKAM", group = _ict_g_KZ)
ict_use_ukpm = input.bool(true, "", inline = "UKPM", group = _ict_g_KZ)
ict_ukpm = input.session("1900-2200", "", inline = "UKPM", group = _ict_g_KZ)
ict_use_usmorning = input.bool(true, "", inline = "USMORN", group = _ict_g_KZ)
ict_usmorning = input.session("2200-2330", "", inline = "USMORN", group = _ict_g_KZ)
ict_use_nyam = input.bool(true, "", inline = "NYAM", group = _ict_g_KZ)
ict_nyam = input.session("2330-0300", "", inline = "NYAM", group = _ict_g_KZ)
ict_use_nylu = input.bool(true, "", inline = "NYLU", group = _ict_g_KZ)
ict_nylu = input.session("0300-0600", "", inline = "NYLU", group = _ict_g_KZ)

ict_is_us_dst() =>
    int m = month(time, "UTC")
    int d = dayofmonth(time, "UTC")
    (m > 3 and m < 11) or (m == 3 and d >= 10) or (m == 11 and d <= 3)
ict_get_effective_session(string sess, bool is_dst) =>
    sess == "2000-2330" ? (is_dst ? "2000-2230" : "2000-2330") : sess == "2330-0300" ? (is_dst ? "2230-0200" : "2330-0300") : sess == "0300-0600" ? (is_dst ? "0200-0600" : "0300-0600") : sess == "0600-0800" ? "0600-0800" : sess

vwap2_any_kz_just_started() =>
    bool kz = false
    if ict_use_sydney
        string _e_syd = ict_get_effective_session(ict_sydney, ict_is_us_dst())
        kz := kz or (not na(time("", _e_syd, ict_gmt_tz)) and na(time("", _e_syd, ict_gmt_tz)[1]))
    if ict_use_tokyo_am
        kz := kz or (not na(time("", ict_tokyo_am, ict_gmt_tz)) and na(time("", ict_tokyo_am, ict_gmt_tz)[1]))
    if ict_use_tokyolunch
        kz := kz or (not na(time("", ict_tokyolunch, ict_gmt_tz)) and na(time("", ict_tokyolunch, ict_gmt_tz)[1]))
    if ict_use_tokyo_pm
        kz := kz or (not na(time("", ict_tokyo_pm, ict_gmt_tz)) and na(time("", ict_tokyo_pm, ict_gmt_tz)[1]))
    if ict_use_ukmorning
        kz := kz or (not na(time("", ict_ukmorning, ict_gmt_tz)) and na(time("", ict_ukmorning, ict_gmt_tz)[1]))
    if ict_use_ukam
        kz := kz or (not na(time("", ict_ukam, ict_gmt_tz)) and na(time("", ict_ukam, ict_gmt_tz)[1]))
    if ict_use_ukpm
        string _e_ukpm = ict_get_effective_session(ict_ukpm, ict_is_us_dst())
        kz := kz or (not na(time("", _e_ukpm, ict_gmt_tz)) and na(time("", _e_ukpm, ict_gmt_tz)[1]))
    if ict_use_usmorning
        kz := kz or (not na(time("", ict_usmorning, ict_gmt_tz)) and na(time("", ict_usmorning, ict_gmt_tz)[1]))
    if ict_use_nyam
        string _e_na = ict_get_effective_session(ict_nyam, ict_is_us_dst())
        kz := kz or (not na(time("", _e_na, ict_gmt_tz)) and na(time("", _e_na, ict_gmt_tz)[1]))
    if ict_use_nylu
        string _e_nl = ict_get_effective_session(ict_nylu, ict_is_us_dst())
        kz := kz or (not na(time("", _e_nl, ict_gmt_tz)) and na(time("", _e_nl, ict_gmt_tz)[1]))
    kz

vwap2_in_any_kz_session() =>
    bool kz = false
    if ict_use_sydney
        string _e_syd = ict_get_effective_session(ict_sydney, ict_is_us_dst())
        kz := kz or not na(time("", _e_syd, ict_gmt_tz))
    if ict_use_tokyo_am
        kz := kz or not na(time("", ict_tokyo_am, ict_gmt_tz))
    if ict_use_tokyolunch
        kz := kz or not na(time("", ict_tokyolunch, ict_gmt_tz))
    if ict_use_tokyo_pm
        kz := kz or not na(time("", ict_tokyo_pm, ict_gmt_tz))
    if ict_use_ukmorning
        kz := kz or not na(time("", ict_ukmorning, ict_gmt_tz))
    if ict_use_ukam
        kz := kz or not na(time("", ict_ukam, ict_gmt_tz))
    if ict_use_ukpm
        string _e_ukpm = ict_get_effective_session(ict_ukpm, ict_is_us_dst())
        kz := kz or not na(time("", _e_ukpm, ict_gmt_tz))
    if ict_use_usmorning
        kz := kz or not na(time("", ict_usmorning, ict_gmt_tz))
    if ict_use_nyam
        string _e_na = ict_get_effective_session(ict_nyam, ict_is_us_dst())
        kz := kz or not na(time("", _e_na, ict_gmt_tz))
    if ict_use_nylu
        string _e_nl = ict_get_effective_session(ict_nylu, ict_is_us_dst())
        kz := kz or not na(time("", _e_nl, ict_gmt_tz))
    kz

var float _kz_run_high = na
var float _kz_run_low = na
if vwap2_any_kz_just_started()
    _kz_run_high := high
    _kz_run_low := low
else if vwap2_in_any_kz_session()
    _kz_run_high := math.max(nz(_kz_run_high), high)
    _kz_run_low := math.min(nz(_kz_run_low), low)
else
    _kz_run_high := na
    _kz_run_low := na

// ========== Swiggy LONG/SHORT ==========
bool is_4hr_or_higher = timeframe.in_seconds("") >= 14400

grpSwiggy = "Swiggy LONG/SHORT"
showSwiggyLabels = input.bool(true, "Show Swiggy LONG/SHORT Labels", group=grpSwiggy, tooltip="LONG: 1m EMA200 < own EMA24 < own EMA8. SHORT: 1m EMA200 > own EMA24 > own EMA8.")
swiggy_invert_colors = input.bool(false, "Invert colors (LONG=red, SHORT=blue)", group=grpSwiggy, tooltip="OFF: LONG=blue, SHORT=red. ON: LONG=red, SHORT=blue.")

grpEMA = "EMA Lengths"
ema200_length = input.int(200, "EMA200 Length", group=grpEMA)

float ema8   = not is_4hr_or_higher ? ta.ema(close, 8)   : close
float ema14  = not is_4hr_or_higher ? ta.ema(close, 14)  : close
float ema24  = not is_4hr_or_higher ? ta.ema(close, 24)  : close
float ema50  = not is_4hr_or_higher ? ta.ema(close, 50)  : close
float ema100 = not is_4hr_or_higher ? ta.ema(close, 100) : close
float ema200 = not is_4hr_or_higher ? ta.ema(close, ema200_length) : close

float label_atr_offset = ta.atr(14)
bool show_ema = false
bool show_tables_15m_or_higher = timeframe.in_seconds("") >= 900
float ema20 = ta.ema(close, 20)
float ema400 = ta.ema(close, 400)

// ========== ICT Killzones & Pivots [TFO] (integrated) ==========
// ---------------------------------------- ICT Constant Functions --------------------------------------------------
ict_get_line_type(_style) =>
    switch _style
        "Solid" => line.style_solid
        "Dotted" => line.style_dotted
        "Dashed" => line.style_dashed

ict_get_size(x) =>
    switch x
        "Auto" => size.auto
        "Tiny" => size.tiny
        "Small" => size.small
        "Normal" => size.normal
        "Large" => size.large
        "Huge" => size.huge

ict_get_table_pos(pos) =>
    switch pos
        "Bottom Center" => position.bottom_center
        "Bottom Left" => position.bottom_left
        "Bottom Right" => position.bottom_right
        "Middle Center" => position.middle_center
        "Middle Left" => position.middle_left
        "Middle Right" => position.middle_right
        "Top Center" => position.top_center
        "Top Left" => position.top_left
        "Top Right" => position.top_right
// ---------------------------------------- ICT Inputs --------------------------------------------------
var ict_g_SETTINGS      = "ICT Settings"
ict_max_days            = input.int(28, "Session Drawing Limit", 1, tooltip = "Only this many drawings will be kept on the chart, for each selected drawing type (killzone boxes, pivot lines, open lines, etc.)", group = ict_g_SETTINGS)
ict_tf_limit            = input.timeframe("D", "Timeframe Limit", tooltip = "Drawings will not appear on timeframes greater than or equal to this. Default D = show on all timeframes up to Daily.", group = ict_g_SETTINGS)
ict_lbl_size            = ict_get_size(input.string('Normal', "Label Size", options = ['Auto', 'Tiny', 'Small', 'Normal', 'Large', 'Huge'], tooltip = "The size of all labels", group = ict_g_SETTINGS))
ict_txt_color           = input.color(color.black, "Text Color", tooltip = "The color of all label and table text", group = ict_g_SETTINGS)
ict_use_cutoff          = input.bool(false, "Drawing Cutoff Time", inline = "CO", tooltip = "When enabled, all pivots and open price lines will stop extending at this time", group = ict_g_SETTINGS)
ict_cutoff              = input.session("1800-1801", "", inline = "CO", group = ict_g_SETTINGS)

bool ict_tf_limit_is_equal_or_more_chart_tf = timeframe.in_seconds('') <= timeframe.in_seconds(ict_tf_limit)

