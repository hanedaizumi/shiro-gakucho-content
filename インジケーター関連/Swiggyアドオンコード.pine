             ict_kz.new(ict_ukmorning_txt, array.new_box(), array.new_line(), array.new_line(), array.new_line(), array.new_label(), array.new_label(), array.new_bool(), array.new_bool(), array.new_bool(), array.new_float(), na, na, na, na, na, na, array.new_line(), array.new_box()),
             ict_ukmorning, ict_ukmorning_color, ict_ukmorning_txt, ict_ukmorning_h_str, ict_ukmorning_l_str
         ))
    if ict_use_ukam
        res.push(ict_kz_helper.new(
             ict_kz.new(ict_ukam_txt, array.new_box(), array.new_line(), array.new_line(), array.new_line(), array.new_label(), array.new_label(), array.new_bool(), array.new_bool(), array.new_bool(), array.new_float(), na, na, na, na, na, na, array.new_line(), array.new_box()),
             ict_ukam, ict_ukam_color, ict_ukam_txt, ict_ukam_h_str, ict_ukam_l_str
         ))
    if ict_use_ukpm
        res.push(ict_kz_helper.new(
             ict_kz.new(ict_ukpm_txt, array.new_box(), array.new_line(), array.new_line(), array.new_line(), array.new_label(), array.new_label(), array.new_bool(), array.new_bool(), array.new_bool(), array.new_float(), na, na, na, na, na, na, array.new_line(), array.new_box()),
             ict_ukpm, ict_ukpm_color, ict_ukpm_txt, ict_ukpm_h_str, ict_ukpm_l_str
         ))
    if ict_use_usmorning
        res.push(ict_kz_helper.new(
             ict_kz.new(ict_usmorning_txt, array.new_box(), array.new_line(), array.new_line(), array.new_line(), array.new_label(), array.new_label(), array.new_bool(), array.new_bool(), array.new_bool(), array.new_float(), na, na, na, na, na, na, array.new_line(), array.new_box()),
             ict_usmorning, ict_usmorning_color, ict_usmorning_txt, ict_usmorning_h_str, ict_usmorning_l_str
