ict_h3_color            = input.color(color.black, "", inline = "H3", group = ict_g_OPEN)

ict_use_h4              = input.bool(false, "", inline = "H4", group = ict_g_OPEN)
ict_h4_text             = input.string("14:00", "", inline = "H4", group = ict_g_OPEN)
ict_h4                  = input.session("1400-1401", "", inline = "H4", group = ict_g_OPEN)
ict_h4_color            = input.color(color.black, "", inline = "H4", group = ict_g_OPEN)

ict_use_h5              = input.bool(false, "", inline = "H5", group = ict_g_OPEN)
ict_h5_text             = input.string("00:00", "", inline = "H5", group = ict_g_OPEN)
ict_h5                  = input.session("0000-0001", "", inline = "H5", group = ict_g_OPEN)
ict_h5_color            = input.color(color.black, "", inline = "H5", group = ict_g_OPEN)

ict_use_h6              = input.bool(false, "", inline = "H6", group = ict_g_OPEN)
ict_h6_text             = input.string("00:00", "", inline = "H6", group = ict_g_OPEN)
ict_h6                  = input.session("0000-0001", "", inline = "H6", group = ict_g_OPEN)
ict_h6_color            = input.color(color.black, "", inline = "H6", group = ict_g_OPEN)

ict_use_h7              = input.bool(false, "", inline = "H7", group = ict_g_OPEN)
ict_h7_text             = input.string("00:00", "", inline = "H7", group = ict_g_OPEN)
ict_h7                  = input.session("0000-0001", "", inline = "H7", group = ict_g_OPEN)
ict_h7_color            = input.color(color.black, "", inline = "H7", group = ict_g_OPEN)

ict_use_h8              = input.bool(false, "", inline = "H8", group = ict_g_OPEN)
ict_h8_text             = input.string("00:00", "", inline = "H8", group = ict_g_OPEN)
ict_h8                  = input.session("0000-0001", "", inline = "H8", group = ict_g_OPEN)
ict_h8_color            = input.color(color.black, "", inline = "H8", group = ict_g_OPEN)

ict_hz_style            = ict_get_line_type(input.string(defval = 'Dotted', title = "Style", options = ['Solid', 'Dotted', 'Dashed'], inline = "H0", group = ict_g_OPEN))
ict_hz_width            = input.int(1, "", inline = "H0", group = ict_g_OPEN)


var ict_g_VERTICAL      = "ICT Timestamps"
ict_v_unlimited         = input.bool(false, "Unlimited", tooltip = "Unlimited will show as many of the selected lines as possible. Otherwise, the session drawing limit will be used", group = ict_g_VERTICAL)

ict_use_v1              = input.bool(false, "", inline = "V1", group = ict_g_VERTICAL)
ict_v1                  = input.session("0000-0001", "", inline = "V1", group = ict_g_VERTICAL)
ict_v1_color            = input.color(color.black, "", inline = "V1", group = ict_g_VERTICAL)

ict_use_v2              = input.bool(false, "", inline = "V2", group = ict_g_VERTICAL)
ict_v2                  = input.session("0800-0801", "", inline = "V2", group = ict_g_VERTICAL)
ict_v2_color            = input.color(color.black, "", inline = "V2", group = ict_g_VERTICAL)

ict_use_v3              = input.bool(false, "", inline = "V3", group = ict_g_VERTICAL)
ict_v3                  = input.session("1000-1001", "", inline = "V3", group = ict_g_VERTICAL)
ict_v3_color            = input.color(color.black, "", inline = "V3", group = ict_g_VERTICAL)

ict_use_v4              = input.bool(false, "", inline = "V4", group = ict_g_VERTICAL)
ict_v4                  = input.session("1200-1201", "", inline = "V4", group = ict_g_VERTICAL)
ict_v4_color            = input.color(color.black, "", inline = "V4", group = ict_g_VERTICAL)

ict_vl_style            = ict_get_line_type(input.string(defval = 'Dotted', title = "Style", options = ['Solid', 'Dotted', 'Dashed'], inline = "V0", group = ict_g_VERTICAL))
ict_vl_width            = input.int(1, "", inline = "V0", group = ict_g_VERTICAL)
// ---------------------------------------- ICT Inputs --------------------------------------------------


// ---------------------------------------- ICT Variables & Constants --------------------------------------------------
type ict_kz
	string _title
	array<box> _box
	array<line> _hi_line
	array<line> _md_line
	array<line> _lo_line
	array<label> _hi_label
	array<label> _lo_label
	array<bool> _hi_valid
	array<bool> _md_valid
	array<bool> _lo_valid
	array<float> _range_store
	float _range_current
	int _last_session_start = na
	int _last_session_end = na
	float _last_box_top = na
	float _last_box_bottom = na
	box _preview_box = na
	array<line> _fib_lines
	array<box> _fib_fill_boxes

type ict_hz
	array<line> LN
	array<label> LB
	array<bool> CO

type ict_dwm_hl
	array<line> hi_line
	array<line> lo_line
	array<label> hi_label
	array<label> lo_label
	bool hit_high = false
	bool hit_low = false

type ict_dwm_info
	string tf
	float o = na
	float h = na
	float l = na
	float ph = na
	float pl = na

type ict_lines_helper
    ict_hz _hz
    string h
    string h_text
    color h_color

ict_initLines() =>
    array<ict_lines_helper> res = array.new<ict_lines_helper>()
    if ict_use_h1
        res.push(ict_lines_helper.new(ict_hz.new(array.new_line(), array.new_label(), array.new_bool()), ict_h1, ict_h1_text, ict_h1_color))
    if ict_use_h2
        res.push(ict_lines_helper.new(ict_hz.new(array.new_line(), array.new_label(), array.new_bool()), ict_h2, ict_h2_text, ict_h2_color))
    if ict_use_h3
        res.push(ict_lines_helper.new(ict_hz.new(array.new_line(), array.new_label(), array.new_bool()), ict_h3, ict_h3_text, ict_h3_color))
    if ict_use_h4
        res.push(ict_lines_helper.new(ict_hz.new(array.new_line(), array.new_label(), array.new_bool()), ict_h4, ict_h4_text, ict_h4_color))
    if ict_use_h5
        res.push(ict_lines_helper.new(ict_hz.new(array.new_line(), array.new_label(), array.new_bool()), ict_h5, ict_h5_text, ict_h5_color))
    if ict_use_h6
        res.push(ict_lines_helper.new(ict_hz.new(array.new_line(), array.new_label(), array.new_bool()), ict_h6, ict_h6_text, ict_h6_color))
    if ict_use_h7
        res.push(ict_lines_helper.new(ict_hz.new(array.new_line(), array.new_label(), array.new_bool()), ict_h7, ict_h7_text, ict_h7_color))
    if ict_use_h8
        res.push(ict_lines_helper.new(ict_hz.new(array.new_line(), array.new_label(), array.new_bool()), ict_h8, ict_h8_text, ict_h8_color))
    res

var array<ict_lines_helper> ict_lines = ict_initLines()

type ict_kz_helper
    ict_kz _kz
    string session
    color c
    string box_txt
    string hi_txt
    string lo_txt

