var array<ict_kz_helper> ict_kz = ict_initKZ()

var ict_d_hl = ict_dwm_hl.new(array.new_line(), array.new_line(), array.new_label(), array.new_label())
var ict_w_hl = ict_dwm_hl.new(array.new_line(), array.new_line(), array.new_label(), array.new_label())
var ict_m_hl = ict_dwm_hl.new(array.new_line(), array.new_line(), array.new_label(), array.new_label())

var ict_d_info = ict_dwm_info.new("D")
var ict_w_info = ict_dwm_info.new("W")
var ict_m_info = ict_dwm_info.new("M")

ict_t_co = not na(time("", ict_cutoff, ict_gmt_tz))

type ict_ts_helper
    string session
    array<line> lines
    color c

ict_initTS() =>
    array<ict_ts_helper> res = array.new<ict_ts_helper>()
    if ict_use_v1
        res.push(ict_ts_helper.new(ict_v1, array.new_line(), ict_v1_color))
    if ict_use_v2
        res.push(ict_ts_helper.new(ict_v2, array.new_line(), ict_v2_color))
    if ict_use_v3
        res.push(ict_ts_helper.new(ict_v3, array.new_line(), ict_v3_color))
    if ict_use_v4
        res.push(ict_ts_helper.new(ict_v4, array.new_line(), ict_v4_color))
    res

var array<ict_ts_helper> ict_ts_data = ict_initTS()

var ict_d_sep_line = array.new_line()
var ict_w_sep_line = array.new_line()
var ict_m_sep_line = array.new_line()

var ict_d_line = array.new_line()
var ict_w_line = array.new_line()
var ict_m_line = array.new_line()

var ict_d_label = array.new_label()
var ict_w_label = array.new_label()
var ict_m_label = array.new_label()

var ict_transparent = #ffffff00
var ict_one_hour_ms = 3600000.0
ict_ext_current = ict_ext_which == 'Most Recent'
ict_ext_past = ict_ext_pivots == 'Past Mitigation'

ict_update_dwm_info(ict_dwm_info n) =>
    if timeframe.change(n.tf)
        n.ph := n.h
        n.pl := n.l
        n.o := open
        n.h := high
        n.l := low
    else
        n.h := math.max(high, n.h)
        n.l := math.min(low, n.l)

if ict_dhl or ict_show_d_open
    ict_update_dwm_info(ict_d_info)
if ict_whl or ict_show_w_open
    ict_update_dwm_info(ict_w_info)
if ict_mhl or ict_show_m_open
    ict_update_dwm_info(ict_m_info)
// ---------------------------------------- ICT Variables & Constants --------------------------------------------------


// ---------------------------------------- ICT Functions --------------------------------------------------
ict_get_box_color(color c) =>
    color.new(c, ict_box_transparency)

ict_get_text_color(color c) =>
    color.new(c, ict_text_transparency)

// ---------------------------------------- ICT Functions --------------------------------------------------


// ---------------------------------------- ICT Core Logic --------------------------------------------------
ict_dwm_sep(string tf, bool use, array<line> arr, color col) =>
    if use
        if timeframe.change(tf)
            arr.unshift(line.new(bar_index, high * 1.0001, bar_index, low, style = ict_htf_style, width = ict_htf_width, extend = extend.both, color = col))
            if not ict_sep_unlimited and arr.size() > ict_max_days
                arr.pop().delete()

ict_dwm_open(string tf, bool use, array<line> lns, array<label> lbls, ict_dwm_info n, color col) =>
    if use
        if lns.size() > 0
            lns.get(0).set_x2(time)
            lbls.get(0).set_x(time)
        if timeframe.change(tf)
            lns.unshift(line.new(time, n.o, time, n.o, xloc = xloc.bar_time, style = ict_htf_style, width = ict_htf_width, color = col))
            lbls.unshift(label.new(time, n.o, tf + " OPEN", xloc = xloc.bar_time, style = label.style_label_left, color = ict_transparent, textcolor = ict_txt_color, size = ict_lbl_size))
            if not ict_sep_unlimited and lns.size() > ict_max_days
                lns.pop().delete()
                lbls.pop().delete()

ict_dwm_hl(string tf, bool use, ict_dwm_hl hl, ict_dwm_info n, color col) =>
    if use
        if hl.hi_line.size() > 0
            hl.hi_line.get(0).set_x2(time)
            hl.lo_line.get(0).set_x2(time)
            hl.hi_label.get(0).set_x(time)
            hl.lo_label.get(0).set_x(time)
        if timeframe.change(tf)
            hl.hi_line.unshift(line.new(time, n.ph, time, n.ph, xloc = xloc.bar_time, style = ict_htf_style, width = ict_htf_width, color = col))
            hl.lo_line.unshift(line.new(time, n.pl, time, n.pl, xloc = xloc.bar_time, style = ict_htf_style, width = ict_htf_width, color = col))
            hl.hi_label.unshift(label.new(time, n.ph, "P" + tf + "H", xloc = xloc.bar_time, style = label.style_label_left, color = ict_transparent, textcolor = ict_txt_color, size = ict_lbl_size))
            hl.lo_label.unshift(label.new(time, n.pl, "P" + tf + "L", xloc = xloc.bar_time, style = label.style_label_left, color = ict_transparent, textcolor = ict_txt_color, size = ict_lbl_size))
            hl.hit_high := false
            hl.hit_low := false
            if not ict_sep_unlimited and hl.hi_line.size() > ict_max_days
                hl.hi_line.pop().delete()
                hl.lo_line.pop().delete()
                hl.hi_label.pop().delete()
                hl.lo_label.pop().delete()
        if hl.hi_line.size() > 0 and ict_alert_HL
            if not hl.hit_high and high > hl.hi_line.get(0).get_y1()
                hl.hit_high := true
            if not hl.hit_low and low < hl.lo_line.get(0).get_y1()
                hl.hit_low := true

ict_dwm() =>
    if ict_tf_limit_is_equal_or_more_chart_tf
        ict_dwm_sep("D", ict_ds, ict_d_sep_line, ict_d_color)
        ict_dwm_sep("W", ict_ws, ict_w_sep_line, ict_w_color)
        ict_dwm_sep("M", ict_ms, ict_m_sep_line, ict_m_color)
        ict_dwm_open("D", ict_show_d_open, ict_d_line, ict_d_label, ict_d_info, ict_d_color)
        ict_dwm_open("W", ict_show_w_open, ict_w_line, ict_w_label, ict_w_info, ict_w_color)
        ict_dwm_open("M", ict_show_m_open, ict_m_line, ict_m_label, ict_m_info, ict_m_color)
        ict_dwm_hl("D", ict_dhl, ict_d_hl, ict_d_info, ict_d_color)
        ict_dwm_hl("W", ict_whl, ict_w_hl, ict_w_info, ict_w_color)
        ict_dwm_hl("M", ict_mhl, ict_m_hl, ict_m_info, ict_m_color)

method ict_vline(ict_ts_helper this) =>
    bool t = not na(time("", this.session, ict_gmt_tz))
    bool t_prev = not na(time("", this.session, ict_gmt_tz, bars_back = 1))
    array<line> arr = this.lines
    color col = this.c
    if t and not t_prev
        arr.unshift(line.new(bar_index, high * 1.0001, bar_index, low, style = ict_vl_style, width = ict_vl_width, extend = extend.both, color = col))
    if not ict_v_unlimited
        if arr.size() > ict_max_days
            arr.pop().delete()

ict_vlines() =>
    if ict_tf_limit_is_equal_or_more_chart_tf
        for [_, value] in ict_ts_data
            ict_vline(value)

method ict_hz_line(ict_lines_helper this) =>
    bool t = not na(time("", this.h, ict_gmt_tz))
    bool t_prev = not na(time("", this.h, ict_gmt_tz, bars_back = 1))
    ict_hz hz = this._hz
    string txt = this.h_text
    color col = this.h_color
    if t and not t_prev
        hz.LN.unshift(line.new(bar_index, open, bar_index, open, style = ict_hz_style, width = ict_hz_width, color = col))
        hz.LB.unshift(label.new(bar_index, open, txt, style = label.style_label_left, color = ict_transparent, textcolor = ict_txt_color, size = ict_lbl_size))
        array.unshift(hz.CO, false)
        if not ict_open_unlimited and hz.LN.size() > ict_max_days
            hz.LN.pop().delete()
            hz.LB.pop().delete()
            hz.CO.pop()
    if not t and hz.CO.size() > 0
        if not hz.CO.get(0)
            hz.LN.get(0).set_x2(bar_index)
            hz.LB.get(0).set_x(bar_index)
            if (ict_use_cutoff ? ict_t_co : false)
                hz.CO.set(0, true)

ict_hz_lines() =>
    if ict_tf_limit_is_equal_or_more_chart_tf
        for [_, value] in ict_lines
            ict_hz_line(value)

ict_del_kz(ict_kz k) =>
    if k._box.size() > ict_max_days
        k._box.pop().delete()
    if k._hi_line.size() > ict_max_days
        k._hi_line.pop().delete()
        k._lo_line.pop().delete()
        k._hi_valid.pop()
        k._lo_valid.pop()
        if ict_show_midpoints
            k._md_line.pop().delete()
            k._md_valid.pop()
    if k._hi_label.size() > ict_max_days
        k._hi_label.pop().delete()
        k._lo_label.pop().delete()

ict_update_price_string(label L, float P) =>
    S = L.get_text()
    pre = str.substring(S, 0, str.pos(S, " "))
    str.trim(pre)
    L.set_text(str.format("{0} ({1})", pre, P))

ict_adjust_in_kz(ict_kz kz, bool t) =>
    if t
        kzBox0 = kz._box.get(0)
        kzBox0.set_right(time)
        newTop = math.max(kzBox0.get_top(), high)
        kzBox0.set_top(newTop)
        newBottom = math.min(kzBox0.get_bottom(), low)
        kzBox0.set_bottom(newBottom)
        kz._range_current := newTop - newBottom
        if ict_show_pivots and kz._hi_line.size() > 0
            kzHiLine0 = kz._hi_line.get(0)
            kzHiLine0.set_x2(time)
            if high > kzHiLine0.get_y1()
                kzHiLine0.set_xy1(time, high)
                kzHiLine0.set_xy2(time, high)
            kzLoLine0 = kz._lo_line.get(0)
            kzLoLine0.set_x2(time)
            if low < kzLoLine0.get_y1()
                kzLoLine0.set_xy1(time, low)
                kzLoLine0.set_xy2(time, low)
            if ict_show_midpoints
                kzMidLine0 = kz._md_line.get(0)
                kzMidLine0.set_x2(time)
                kzMidLine0.set_xy1(time, math.avg(kzHiLine0.get_y2(), kzLoLine0.get_y2()))
                kzMidLine0.set_xy2(time, math.avg(kzHiLine0.get_y2(), kzLoLine0.get_y2()))
        if ict_show_labels and kz._hi_label.size() > 0
            if ict_label_right
                kz._hi_label.get(0).set_x(time)
                kz._lo_label.get(0).set_x(time)
            if high > kz._hi_label.get(0).get_y()
                kz._hi_label.get(0).set_xy(time, high)
                if ict_label_price
                    ict_update_price_string(kz._hi_label.get(0), high)
            if low < kz._lo_label.get(0).get_y()
                kz._lo_label.get(0).set_xy(time, low)
                if ict_label_price
                    ict_update_price_string(kz._lo_label.get(0), low)
        if ict_show_kz_fib and kz._fib_lines.size() >= 5
            int _boxLeft = int(kzBox0.get_left())
            float _top = kzBox0.get_top()
            float _bot = kzBox0.get_bottom()
            float _rr = _top - _bot
            float _f764 = _top - 0.236 * _rr
            float _f5 = _top - 0.5 * _rr
            float _f236 = _top - 0.764 * _rr
            kz._fib_lines.get(0).set_xy1(_boxLeft, _top)
            kz._fib_lines.get(0).set_xy2(time, _top)
            kz._fib_lines.get(1).set_xy1(_boxLeft, _f764)
            kz._fib_lines.get(1).set_xy2(time, _f764)
            kz._fib_lines.get(2).set_xy1(_boxLeft, _f5)
            kz._fib_lines.get(2).set_xy2(time, _f5)
            kz._fib_lines.get(3).set_xy1(_boxLeft, _f236)
            kz._fib_lines.get(3).set_xy2(time, _f236)
            kz._fib_lines.get(4).set_xy1(_boxLeft, _bot)
            kz._fib_lines.get(4).set_xy2(time, _bot)
            if kz._fib_fill_boxes.size() >= 4
                kz._fib_fill_boxes.get(0).set_left(_boxLeft)
                kz._fib_fill_boxes.get(0).set_top(_top)
                kz._fib_fill_boxes.get(0).set_right(time)
                kz._fib_fill_boxes.get(0).set_bottom(_f764)
                kz._fib_fill_boxes.get(1).set_left(_boxLeft)
                kz._fib_fill_boxes.get(1).set_top(_f764)
                kz._fib_fill_boxes.get(1).set_right(time)
                kz._fib_fill_boxes.get(1).set_bottom(_f5)
                kz._fib_fill_boxes.get(2).set_left(_boxLeft)
                kz._fib_fill_boxes.get(2).set_top(_f5)
                kz._fib_fill_boxes.get(2).set_right(time)
                kz._fib_fill_boxes.get(2).set_bottom(_f236)
                kz._fib_fill_boxes.get(3).set_left(_boxLeft)
                kz._fib_fill_boxes.get(3).set_top(_f236)
                kz._fib_fill_boxes.get(3).set_right(time)
                kz._fib_fill_boxes.get(3).set_bottom(_bot)
            else
                array.push(kz._fib_fill_boxes, box.new(_boxLeft, _top, time, _f764, xloc = xloc.bar_time, border_color = na, bgcolor = color.new(color.blue, 75)))
                array.push(kz._fib_fill_boxes, box.new(_boxLeft, _f764, time, _f5, xloc = xloc.bar_time, border_color = na, bgcolor = color.new(color.blue, 90)))
                array.push(kz._fib_fill_boxes, box.new(_boxLeft, _f5, time, _f236, xloc = xloc.bar_time, border_color = na, bgcolor = color.new(color.red, 90)))
                array.push(kz._fib_fill_boxes, box.new(_boxLeft, _f236, time, _bot, xloc = xloc.bar_time, border_color = na, bgcolor = color.new(color.red, 75)))

ict_adjust_out_kz(ict_kz kz, bool t, bool t_prev) =>
    boxCount = kz._box.size()
    if not t and boxCount > 0
        if t_prev
            array.unshift(kz._range_store, kz._range_current)
            if kz._range_store.size() > ict_range_avg
                kz._range_store.pop()
            kzBox0 = kz._box.get(0)
            kz._last_session_start := int(kzBox0.get_left())
            kz._last_session_end := int(kzBox0.get_right())
            kz._last_box_top := kzBox0.get_top()
            kz._last_box_bottom := kzBox0.get_bottom()
            if ict_show_kz_fib and not na(kz._last_box_top) and not na(kz._last_box_bottom) and not na(kz._last_session_start)
                float _r = kz._last_box_top - kz._last_box_bottom
                float _f1 = kz._last_box_top
                float _f764 = kz._last_box_top - 0.236 * _r
                float _f5 = kz._last_box_top - 0.5 * _r
                float _f236 = kz._last_box_top - 0.764 * _r
                float _f0 = kz._last_box_bottom
                if kz._fib_lines.size() >= 5
                    kz._fib_lines.get(0).set_xy1(kz._last_session_start, _f1)
                    kz._fib_lines.get(0).set_xy2(kz._last_session_end, _f1)
                    kz._fib_lines.get(1).set_xy1(kz._last_session_start, _f764)
                    kz._fib_lines.get(1).set_xy2(kz._last_session_end, _f764)
                    kz._fib_lines.get(2).set_xy1(kz._last_session_start, _f5)
                    kz._fib_lines.get(2).set_xy2(kz._last_session_end, _f5)
                    kz._fib_lines.get(3).set_xy1(kz._last_session_start, _f236)
                    kz._fib_lines.get(3).set_xy2(kz._last_session_end, _f236)
                    kz._fib_lines.get(4).set_xy1(kz._last_session_start, _f0)
                    kz._fib_lines.get(4).set_xy2(kz._last_session_end, _f0)
                    if kz._fib_fill_boxes.size() >= 4
                        kz._fib_fill_boxes.get(0).set_left(kz._last_session_start)
                        kz._fib_fill_boxes.get(0).set_top(_f1)
                        kz._fib_fill_boxes.get(0).set_right(kz._last_session_end)
                        kz._fib_fill_boxes.get(0).set_bottom(_f764)
                        kz._fib_fill_boxes.get(1).set_left(kz._last_session_start)
                        kz._fib_fill_boxes.get(1).set_top(_f764)
                        kz._fib_fill_boxes.get(1).set_right(kz._last_session_end)
                        kz._fib_fill_boxes.get(1).set_bottom(_f5)
                        kz._fib_fill_boxes.get(2).set_left(kz._last_session_start)
                        kz._fib_fill_boxes.get(2).set_top(_f5)
                        kz._fib_fill_boxes.get(2).set_right(kz._last_session_end)
                        kz._fib_fill_boxes.get(2).set_bottom(_f236)
                        kz._fib_fill_boxes.get(3).set_left(kz._last_session_start)
                        kz._fib_fill_boxes.get(3).set_top(_f236)
                        kz._fib_fill_boxes.get(3).set_right(kz._last_session_end)
                        kz._fib_fill_boxes.get(3).set_bottom(_f0)
                else
                    array.push(kz._fib_lines, line.new(kz._last_session_start, _f1, kz._last_session_end, _f1, xloc = xloc.bar_time, color = color.black, width = 1))
                    array.push(kz._fib_lines, line.new(kz._last_session_start, _f764, kz._last_session_end, _f764, xloc = xloc.bar_time, color = color.blue, width = 1))
                    array.push(kz._fib_lines, line.new(kz._last_session_start, _f5, kz._last_session_end, _f5, xloc = xloc.bar_time, color = color.red, width = 1))
                    array.push(kz._fib_lines, line.new(kz._last_session_start, _f236, kz._last_session_end, _f236, xloc = xloc.bar_time, color = color.red, width = 1))
                    array.push(kz._fib_lines, line.new(kz._last_session_start, _f0, kz._last_session_end, _f0, xloc = xloc.bar_time, color = color.black, width = 1))
                    array.push(kz._fib_fill_boxes, box.new(kz._last_session_start, _f1, kz._last_session_end, _f764, xloc = xloc.bar_time, border_color = na, bgcolor = color.new(color.blue, 75)))
                    array.push(kz._fib_fill_boxes, box.new(kz._last_session_start, _f764, kz._last_session_end, _f5, xloc = xloc.bar_time, border_color = na, bgcolor = color.new(color.blue, 90)))
                    array.push(kz._fib_fill_boxes, box.new(kz._last_session_start, _f5, kz._last_session_end, _f236, xloc = xloc.bar_time, border_color = na, bgcolor = color.new(color.red, 90)))
                    array.push(kz._fib_fill_boxes, box.new(kz._last_session_start, _f236, kz._last_session_end, _f0, xloc = xloc.bar_time, border_color = na, bgcolor = color.new(color.red, 75)))
    if ict_show_pivots and boxCount > 0
        for i = 0 to boxCount - 1 by 1
            if not ict_ext_current or i == 0
                kzHiValid = kz._hi_valid.get(i)
                if ict_ext_past or kzHiValid
                    kz._hi_line.get(i).set_x2(time)
                    if ict_show_labels and ict_label_right
                        kz._hi_label.get(i).set_x(time)
                if kzHiValid and high > kz._hi_line.get(i).get_y1()
                    kz._hi_valid.set(i, false)
                    if ict_show_labels and ict_label_right
                        kz._hi_label.get(i).set_style(label.style_label_down)
                else if ict_use_cutoff ? ict_t_co : false
                    kz._hi_valid.set(i, false)
                kzLoValid = kz._lo_valid.get(i)
                if ict_ext_past or kzLoValid
                    kz._lo_line.get(i).set_x2(time)
                    if ict_show_labels and ict_label_right
                        kz._lo_label.get(i).set_x(time)
                if kzLoValid and low < kz._lo_line.get(i).get_y1()
                    kz._lo_valid.set(i, false)
                    if ict_show_labels and ict_label_right
                        kz._lo_label.get(i).set_style(label.style_label_up)
                else if ict_use_cutoff ? ict_t_co : false
                    kz._lo_valid.set(i, false)
                if ict_show_midpoints and not t
                    if ict_stop_midpoints ? kz._md_valid.get(i) : true
                        kz._md_line.get(i).set_x2(time)
                        if kz._md_valid.get(i) and low <= kz._md_line.get(i).get_y1() and high >= kz._md_line.get(i).get_y1()
                            kz._md_valid.set(i, false)
            else
                break

method ict_manage_kz(ict_kz_helper this) =>
    ict_kz kz = this._kz
    c = this.c
    string box_txt = this.box_txt
    string hi_txt = this.hi_txt
    string lo_txt = this.lo_txt
    string eff_session = ict_get_effective_session(this.session, ict_is_us_dst())
    if ict_tf_limit_is_equal_or_more_chart_tf
        t = not na(time("", eff_session, ict_gmt_tz))
        t_prev = not na(time("", eff_session, ict_gmt_tz, bars_back = 1))
        if t and not t_prev
            if not na(kz._preview_box)
                kz._preview_box.delete()
                kz._preview_box := na
            int _dow = dayofweek(time, ict_gmt_tz)
            bool _is_weekday = _dow >= 2 and _dow <= 6
            bool _show_this_kz = ict_show_kz and (not ict_kz_weekdays_only or _is_weekday)
            _c = ict_get_box_color(c)
            _t = ict_get_text_color(c)
            color _bg = _show_this_kz ? color.new(c, 85) : na
            color _txt = _show_this_kz and ict_show_kz_text ? color.new(c, 80) : na
            kz._box.unshift(box.new(time, high, time, low, xloc = xloc.bar_time, border_color = _show_this_kz ? _c : na, bgcolor = _bg, text = _show_this_kz and ict_show_kz_text ? box_txt : na, text_color = _txt))
            if ict_show_pivots
                kz._hi_line.unshift(line.new(time, high, time, high, xloc = xloc.bar_time, style = ict_kzp_style, color = c, width = ict_kzp_width))
                kz._lo_line.unshift(line.new(time, low, time, low, xloc = xloc.bar_time, style = ict_kzp_style, color = c, width = ict_kzp_width))
                if ict_show_midpoints
                    kz._md_line.unshift(line.new(time, math.avg(high, low), time, math.avg(high, low), xloc = xloc.bar_time, style = ict_kzm_style, color = c, width = ict_kzm_width))
                    array.unshift(kz._md_valid, true)
                array.unshift(kz._hi_valid, true)
                array.unshift(kz._lo_valid, true)
                if ict_show_labels
                    _hi_txt = ict_label_price ? str.format('{0} ({1})', hi_txt, high) : hi_txt
                    _lo_txt = ict_label_price ? str.format('{0} ({1})', lo_txt, low) : lo_txt
                    if ict_label_right
                        kz._hi_label.unshift(label.new(time, high, _hi_txt, xloc = xloc.bar_time, color = ict_transparent, textcolor = ict_txt_color, style = label.style_label_left, size = ict_lbl_size))
                        kz._lo_label.unshift(label.new(time, low, _lo_txt, xloc = xloc.bar_time, color = ict_transparent, textcolor = ict_txt_color, style = label.style_label_left, size = ict_lbl_size))
                    else
                        kz._hi_label.unshift(label.new(time, high, _hi_txt, xloc = xloc.bar_time, color = ict_transparent, textcolor = ict_txt_color, style = label.style_label_down, size = ict_lbl_size))
                        kz._lo_label.unshift(label.new(time, low, _lo_txt, xloc = xloc.bar_time, color = ict_transparent, textcolor = ict_txt_color, style = label.style_label_up, size = ict_lbl_size))
            if t and not t_prev and ict_show_kz_fib
                if kz._fib_lines.size() > 0
                    for _j = 0 to kz._fib_lines.size() - 1
                        line.delete(kz._fib_lines.get(_j))
                    array.clear(kz._fib_lines)
                if kz._fib_fill_boxes.size() > 0
                    for _j = 0 to kz._fib_fill_boxes.size() - 1
                        box.delete(kz._fib_fill_boxes.get(_j))
                    array.clear(kz._fib_fill_boxes)
                float _r0 = high - low
                float _f1_0 = high
                float _f764_0 = high - 0.236 * _r0
                float _f5_0 = high - 0.5 * _r0
                float _f236_0 = high - 0.764 * _r0
                float _f0_0 = low
                array.push(kz._fib_lines, line.new(time, _f1_0, time, _f1_0, xloc = xloc.bar_time, color = color.black, width = 1))
                array.push(kz._fib_lines, line.new(time, _f764_0, time, _f764_0, xloc = xloc.bar_time, color = color.blue, width = 1))
                array.push(kz._fib_lines, line.new(time, _f5_0, time, _f5_0, xloc = xloc.bar_time, color = color.red, width = 1))
                array.push(kz._fib_lines, line.new(time, _f236_0, time, _f236_0, xloc = xloc.bar_time, color = color.red, width = 1))
                array.push(kz._fib_lines, line.new(time, _f0_0, time, _f0_0, xloc = xloc.bar_time, color = color.black, width = 1))
            ict_del_kz(kz)
        ict_adjust_in_kz(kz, t)
        ict_adjust_out_kz(kz, t, t_prev)
        next_start = not na(kz._last_session_start) ? kz._last_session_start + 24 * 3600000 : na
        next_end = not na(kz._last_session_end) ? kz._last_session_end + 24 * 3600000 : na
        in_preview = not na(next_start) and time >= next_start - int(2 * ict_one_hour_ms) and time < next_start
        int _next_dow = not na(next_start) ? dayofweek(next_start, ict_gmt_tz) : 0
        bool _next_weekday = _next_dow >= 2 and _next_dow <= 6
        bool _show_preview = ict_show_kz and (not ict_kz_weekdays_only or _next_weekday) and not na(kz._last_box_top) and not na(kz._last_box_bottom)
        if in_preview and _show_preview
            if na(kz._preview_box)
                _c = ict_get_box_color(c)
                string _preview_txt = "Seek\n ICT chart pattern\nover the current &\nupcoming Killzones."
                kz._preview_box := box.new(int(next_start), kz._last_box_top, int(next_end), kz._last_box_bottom, xloc = xloc.bar_time, border_color = _c, bgcolor = color.new(color.green, 60), text = ict_show_kz_text ? _preview_txt : na, text_color = color.new(color.black, 80))
        else if not in_preview and not na(kz._preview_box)
            kz._preview_box.delete()
            kz._preview_box := na

for [_, value] in ict_kz
    ict_manage_kz(value)

plot(na, color=color.orange, linewidth=1, title="")  // EMA7 非表示
ema20_plot = plot(show_ema and not is_4hr_or_higher ? ema20 : na, color=color.green, linewidth=2, title="EMA20")
ema50_plot = plot(show_ema and not is_4hr_or_higher ? ema50 : na, color=color.red, linewidth=2, title="EMA50")
ema100_plot = plot(show_ema and not is_4hr_or_higher ? ema100 : na, color=color.blue, linewidth=2, title="EMA100")
plot(show_ema and not is_4hr_or_higher ? ema200 : na, color=color.purple, linewidth=3, title="EMA200")
plot(show_ema and not is_4hr_or_higher ? ema400 : na, color=color.gray, linewidth=2, title="EMA400")

ict_dwm()
ict_vlines()
ict_hz_lines()

ict_new_dow_time = ict_dow_xloc == 'Midday' ? time - timeframe.in_seconds("D") / 2 * 1000 : time
ict_new_day = dayofweek(ict_new_dow_time, ict_gmt_tz) != dayofweek(ict_new_dow_time, ict_gmt_tz)[1]
var ict_dow_top = ict_dow_yloc == 'Top'

var ict_saturday = "SATURDAY"
var ict_sunday = "SUNDAY"
var ict_monday = "MONDAY"
var ict_tuesday = "TUESDAY"
var ict_wednesday = "WEDNESDAY"
var ict_thursday = "THURSDAY"
var ict_friday = "FRIDAY"

plotchar(ict_dow_labels and not show_tables_15m_or_higher and timeframe.isintraday and dayofweek(ict_new_dow_time, ict_gmt_tz) == 1 and ict_new_day and not ict_dow_hide_wknd, location = ict_dow_top ? location.top : location.bottom, char = '', textcolor = ict_txt_color, text = ict_sunday)
plotchar(ict_dow_labels and not show_tables_15m_or_higher and timeframe.isintraday and dayofweek(ict_new_dow_time, ict_gmt_tz) == 2 and ict_new_day, location = ict_dow_top ? location.top : location.bottom, char = '', textcolor = ict_txt_color, text = ict_monday)
plotchar(ict_dow_labels and not show_tables_15m_or_higher and timeframe.isintraday and dayofweek(ict_new_dow_time, ict_gmt_tz) == 3 and ict_new_day, location = ict_dow_top ? location.top : location.bottom, char = '', textcolor = ict_txt_color, text = ict_tuesday)
plotchar(ict_dow_labels and not show_tables_15m_or_higher and timeframe.isintraday and dayofweek(ict_new_dow_time, ict_gmt_tz) == 4 and ict_new_day, location = ict_dow_top ? location.top : location.bottom, char = '', textcolor = ict_txt_color, text = ict_wednesday)
plotchar(ict_dow_labels and not show_tables_15m_or_higher and timeframe.isintraday and dayofweek(ict_new_dow_time, ict_gmt_tz) == 5 and ict_new_day, location = ict_dow_top ? location.top : location.bottom, char = '', textcolor = ict_txt_color, text = ict_thursday)
plotchar(ict_dow_labels and not show_tables_15m_or_higher and timeframe.isintraday and dayofweek(ict_new_dow_time, ict_gmt_tz) == 6 and ict_new_day, location = ict_dow_top ? location.top : location.bottom, char = '', textcolor = ict_txt_color, text = ict_friday)
plotchar(ict_dow_labels and not show_tables_15m_or_higher and timeframe.isintraday and dayofweek(ict_new_dow_time, ict_gmt_tz) == 7 and ict_new_day and not ict_dow_hide_wknd, location = ict_dow_top ? location.top : location.bottom, char = '', textcolor = ict_txt_color, text = ict_saturday)

ict_get_min_days_stored() =>
    store = array.new_int()
    for [_, value] in ict_kz
        int tmpStoreSize = value._kz._range_store.size()
        if tmpStoreSize > 0
            store.push(tmpStoreSize)
    store.min()

method ict_set_table(table tbl, ict_kz kz, int row, string txt, bool t, color col) =>
    table.cell(tbl, 0, row, txt, text_size = ict_range_size, bgcolor = color.new(col, 60), text_color = ict_txt_color)
    table.cell(tbl, 1, row, str.tostring(kz._range_current), text_size = ict_range_size, bgcolor = t ? color.new(col, 60) : na, text_color = ict_txt_color)
    if ict_show_range_avg
        table.cell(tbl, 2, row, str.tostring(kz._range_store.avg()), text_size = ict_range_size, text_color = ict_txt_color)

if ict_show_range and barstate.islast
    var ict_tbl = table.new(ict_range_pos, 10, 10, color.new(chart.bg_color, 60), chart.fg_color, 0, chart.fg_color, 1)
    table.cell(ict_tbl, 0, 0, "Killzone", text_size = ict_range_size, text_color = ict_txt_color)
    table.cell(ict_tbl, 1, 0, "Range", text_size = ict_range_size, text_color = ict_txt_color)
    if ict_show_range_avg
        table.cell(ict_tbl, 2, 0, "Avg (" + str.tostring(ict_get_min_days_stored()) + ")", text_size = ict_range_size, text_color = ict_txt_color)
    for [index, value] in ict_kz
        ict_set_table(ict_tbl, value._kz, index + 1, value.box_txt, not na(time("", ict_get_effective_session(value.session, ict_is_us_dst()), ict_gmt_tz)), value.c)
// ---------------------------------------- ICT Core Logic --------------------------------------------------


bool swiggy_long_cond  = not is_4hr_or_higher and ema100 < ema50 and ema24 < ema8
bool swiggy_short_cond = not is_4hr_or_higher and ema100 > ema50 and ema24 > ema8

bool swiggy_long_just  = swiggy_long_cond and not swiggy_long_cond[1]
bool swiggy_short_just = swiggy_short_cond and not swiggy_short_cond[1]

bool swiggy_bearish_order = not is_4hr_or_higher and ema14 < ema50 and ema50 < ema100 and ema100 < ema200
bool swiggy_bullish_order = not is_4hr_or_higher and ema14 > ema50 and ema50 > ema100 and ema100 > ema200
bool swiggy_long_first_cross  = ema24 < ema8 and ema24[1] >= ema8[1]
bool swiggy_short_first_cross  = ema24 > ema8 and ema24[1] <= ema8[1]

var bool swiggy_long_once_shown  = false
var bool swiggy_short_once_shown = false
if not swiggy_bearish_order
    swiggy_long_once_shown := false
if not swiggy_bullish_order
    swiggy_short_once_shown := false

bool swiggy_long_once_cond  = swiggy_bearish_order and swiggy_long_first_cross and not swiggy_long_once_shown
bool swiggy_short_once_cond = swiggy_bullish_order and swiggy_short_first_cross and not swiggy_short_once_shown

color _swiggy_long_bg  = color.new(swiggy_invert_colors ? color.red : color.blue, 20)
color _swiggy_short_bg = color.new(swiggy_invert_colors ? color.blue : color.red, 20)

if showSwiggyLabels and (swiggy_long_just or swiggy_long_once_cond)
    label.new(bar_index, low - label_atr_offset * 1.2, "Swiggy\nLONG", style=label.style_label_up, size=size.tiny, color=_swiggy_long_bg, textcolor=color.white)
    if swiggy_long_once_cond
        swiggy_long_once_shown := true

if showSwiggyLabels and (swiggy_short_just or swiggy_short_once_cond)
    label.new(bar_index, high + label_atr_offset * 1.2, "Swiggy\nSHORT", style=label.style_label_down, size=size.tiny, color=_swiggy_short_bg, textcolor=color.white)
    if swiggy_short_once_cond
        swiggy_short_once_shown := true

// ═══════════════════════════════════════════════════════════════════════════
// Swiggy Alerts
// ═══════════════════════════════════════════════════════════════════════════
bool alert_swiggy_long  = showSwiggyLabels and (swiggy_long_just or swiggy_long_once_cond)
bool alert_swiggy_short = showSwiggyLabels and (swiggy_short_just or swiggy_short_once_cond)

string _alert_interval = timeframe.period

// 1) All Swiggy LONG/SHORT
bool _any_swiggy = alert_swiggy_long or alert_swiggy_short
if _any_swiggy
    string _long_part  = alert_swiggy_long  ? "LONG: Swiggy" : ""
    string _short_part = alert_swiggy_short ? "SHORT: Swiggy" : ""
    string _msg_all = _long_part + (_long_part != "" and _short_part != "" ? " | " : "") + _short_part + " | " + syminfo.ticker + " | " + _alert_interval
    alert(_msg_all, alert.freq_once_per_bar)

if alert_swiggy_long
    alert("LONG Swiggy " + syminfo.ticker + " " + _alert_interval, alert.freq_once_per_bar)

if alert_swiggy_short
    alert("SHORT Swiggy " + syminfo.ticker + " " + _alert_interval, alert.freq_once_per_bar)

alertcondition(_any_swiggy, "Swiggy LONG/SHORT (All)", "{{ticker}} | {{interval}}")
alertcondition(alert_swiggy_long, "Swiggy LONG only", "LONG | {{ticker}} | {{interval}}")
alertcondition(alert_swiggy_short, "Swiggy SHORT only", "SHORT | {{ticker}} | {{interval}}")
